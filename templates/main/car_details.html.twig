<!-- Enhanced Car Details Template with Professional Carousel -->
<div class="mb-6 flex justify-between items-center">
    <div>
        <h1 class="text-3xl font-bold text-gray-100">Vehicle Details</h1>
    </div>
    <a href="{{ path('app_inventory') }}" 
       class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition-colors duration-200 shadow-lg hover:shadow-xl">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to Inventory
    </a>
</div>

<div class="bg-gray-800 rounded-xl shadow-lg border border-gray-700 overflow-hidden" data-controller="vehicle-details">
    <!-- Header Section -->
    <div class="bg-gradient-to-r from-gray-900 to-gray-800 px-4 py-2 border-b border-gray-700">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-3xl font-bold text-white mb-2">{{ car.brand }}</h2>
                <div class="flex items-center space-x-6 text-gray-300">
                    <span class="flex items-center text-lg">
                        <svg class="w-5 h-5 mr-2 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        {{ car.year }}
                    </span>
                </div>
            </div>
            <div class="text-right">
                <div class="text-4xl font-bold text-[#B32224] mb-2">₱{{ car.price|number_format(2, '.', ',') }}</div>
                {% if car.status == 'sold' %}
                    <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-red-100 text-red-800">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 8 8">
                            <circle cx="4" cy="4" r="3"/>
                        </svg>
                        Sold
                    </span>
                {% elseif car.status == 'reserved' %}
                    <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 8 8">
                            <circle cx="4" cy="4" r="3"/>
                        </svg>
                        Reserved
                    </span>
                {% else %}
                    <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-green-100 text-green-800">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 8 8">
                            <circle cx="4" cy="4" r="3"/>
                        </svg>
                        Available
                    </span>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
        <!-- Image Carousel Section -->
        <div class="relative bg-gradient-to-br from-gray-900 to-gray-800">
            {% if car.images is not empty %}
                <!-- Main Carousel -->
                <div class="relative h-96 lg:h-full min-h-[400px] overflow-hidden group">
                    {% for image in car.images %}
                        <div class="carousel-slide {% if loop.first %}active{% endif %} absolute inset-0 transition-opacity duration-500 ease-in-out">
                            <img src="{{ asset('uploads/cars/' ~ image) }}" 
                                 alt="{{ car.brand }} - Image {{ loop.index }}" 
                                 class="w-full h-full object-cover cursor-pointer hover:scale-105 transition-transform duration-500 carousel-image"
                                 data-image-index="{{ loop.index0 }}"
                                 data-images="{{ car.images|json_encode|escape('html_attr') }}"
                                 data-brand="{{ car.brand|escape('html_attr') }}">
                        </div>
                    {% endfor %}
                    
                    <!-- Navigation Arrows -->
                    {% if car.images|length > 1 %}
                        <button class="carousel-prev absolute left-4 top-1/2 transform -translate-y-1/2 bg-black/50 hover:bg-black/75 text-white p-3 rounded-full transition-all duration-200 opacity-0 group-hover:opacity-100 shadow-lg">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                            </svg>
                        </button>
                        <button class="carousel-next absolute right-4 top-1/2 transform -translate-y-1/2 bg-black/50 hover:bg-black/75 text-white p-3 rounded-full transition-all duration-200 opacity-0 group-hover:opacity-100 shadow-lg">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </button>
                    {% endif %}
                    
                    <!-- Image Counter -->
                    {% if car.images|length > 1 %}
                        <div class="absolute bottom-4 right-4 bg-black/75 backdrop-blur-sm text-white px-3 py-1 rounded-full text-sm font-medium shadow-lg">
                            <span class="current-slide">1</span>/{{ car.images|length }}
                        </div>
                    {% endif %}
                    
                    <!-- Gradient Overlay -->
                    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-black/40 to-transparent pointer-events-none"></div>
                </div>
                
                <!-- Thumbnail Navigation -->
                {% if car.images|length > 1 %}
                    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-4">
                        <div class="flex space-x-2 overflow-x-auto pb-2">
                            {% for image in car.images %}
                                <button class="thumbnail-btn flex-shrink-0 w-16 h-12 rounded-lg overflow-hidden border-2 border-transparent hover:border-white transition-all duration-200 {% if loop.first %}border-white{% endif %} shadow-lg"
                                        data-slide="{{ loop.index0 }}">
                                    <img src="{{ asset('uploads/cars/' ~ image) }}" 
                                         alt="Thumbnail {{ loop.index }}" 
                                         class="w-full h-full object-cover">
                                </button>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            {% else %}
                <!-- No Images Placeholder -->
                <div class="h-96 lg:h-full min-h-[400px] flex items-center justify-center bg-gradient-to-br from-gray-900 to-gray-800">
                    <div class="text-center text-gray-400">
                        <svg class="w-16 h-16 mx-auto mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        <p class="text-lg font-medium text-gray-300">No images available</p>
                        <p class="text-sm text-gray-500">Images will appear here once uploaded</p>
                    </div>
                </div>
            {% endif %}
        </div>

        <!-- Vehicle Information Section -->
        <div class="p-6 lg:p-8 bg-gray-800">
            <!-- Key Features Grid -->
            <div class="grid grid-cols-2 gap-4 mb-8">
                <div class="bg-gray-700 rounded-lg p-4 border border-gray-600">
                    <div class="flex items-center mb-2">
                        <svg class="w-5 h-5 text-emerald-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                        <span class="text-sm font-medium text-gray-300">Mileage</span>
                    </div>
                    <p class="text-lg font-semibold text-white">{{ car.mileage }} km</p>
                </div>
                <div class="bg-gray-700 rounded-lg p-4 border border-gray-600">
                    <div class="flex items-center mb-2">
                        <svg class="w-5 h-5 text-amber-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <span class="text-sm font-medium text-gray-300">Condition</span>
                    </div>
                    <p class="text-lg font-semibold text-white">{{ car.conditions }}</p>
                </div>
            </div>

            <!-- Additional Vehicle Information -->
            <div class="grid grid-cols-2 gap-4 mb-8">
                {% if car.make %}
                <div class="bg-gray-700 rounded-lg p-4 border border-gray-600">
                    <div class="flex items-center mb-2">
                        <svg class="w-5 h-5 text-blue-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                        </svg>
                        <span class="text-sm font-medium text-gray-300">Make</span>
                    </div>
                    <p class="text-lg font-semibold text-white">{{ car.make }}</p>
                </div>
                {% endif %}
                
                {% if car.color %}
                <div class="bg-gray-700 rounded-lg p-4 border border-gray-600">
                    <div class="flex items-center mb-2">
                        <svg class="w-5 h-5 text-purple-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zM21 5a2 2 0 00-2-2h-4a2 2 0 00-2 2v12a4 4 0 004 4h4a2 2 0 002-2V5z"/>
                        </svg>
                        <span class="text-sm font-medium text-gray-300">Color</span>
                    </div>
                    <p class="text-lg font-semibold text-white">{{ car.color }}</p>
                </div>
                {% endif %}
                
                {% if car.plateNumber %}
                <div class="bg-gray-700 rounded-lg p-4 border border-gray-600">
                    <div class="flex items-center mb-2">
                        <svg class="w-5 h-5 text-cyan-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        <span class="text-sm font-medium text-gray-300">Plate Number</span>
                    </div>
                    <p class="text-lg font-semibold text-white">{{ car.plateNumber }}</p>
                </div>
                {% endif %}
                
                {% if car.engineNumber %}
                <div class="bg-gray-700 rounded-lg p-4 border border-gray-600">
                    <div class="flex items-center mb-2">
                        <svg class="w-5 h-5 text-orange-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        <span class="text-sm font-medium text-gray-300">Engine Number</span>
                    </div>
                    <p class="text-lg font-semibold text-white">{{ car.engineNumber }}</p>
                </div>
                {% endif %}
            </div>

            <!-- Damage Description -->
            {% if car.damageDescription %}
            <div class="mb-8">
                <div class="bg-gray-700 rounded-lg p-4 border border-gray-600">
                    <div class="flex items-center mb-2">
                        <svg class="w-5 h-5 text-red-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                        </svg>
                        <span class="text-sm font-medium text-gray-300">Damage Description</span>
                    </div>
                    <p class="text-sm text-gray-200 leading-relaxed">{{ car.damageDescription }}</p>
                </div>
            </div>
            {% endif %}

            <!-- Action Buttons -->
            <div class="space-y-4">
                <!-- Primary Actions -->
                <div class="flex gap-3">
                    <button onclick="openEditModal('{{ car.id }}')"
                            class="flex-1 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white rounded-lg px-4 py-3 transition-all duration-200 flex items-center justify-center gap-2 shadow-lg hover:shadow-xl transform hover:scale-105">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                        Edit Vehicle
                    </button>
                    <button onclick="handleDelete('{{ car.id }}', '{{ csrf_token('delete' ~ car.id) }}')"
                            class="px-4 py-3 border border-red-300 rounded-lg text-red-300 hover:bg-red-600 hover:text-white hover:border-red-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-all duration-200 flex items-center gap-2 shadow-lg hover:shadow-xl">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                        Delete
                    </button>
                </div>
                
                <!-- Quick Sale Action -->
                {% if car.status == 'available' %}
                    <div class="mt-6 p-4 bg-gradient-to-r from-green-900/20 to-green-800/20 border border-green-700/30 rounded-lg">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center">
                                <svg class="w-5 h-5 text-green-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                <span class="text-green-300 text-sm font-medium">Ready for sale</span>
                            </div>
                            <a href="{{ path('app_sales_new') }}?vehicle={{ car.id }}" 
                               class="bg-gradient-to-r from-emerald-600 to-emerald-700 hover:from-emerald-700 hover:to-emerald-800 text-white px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105">
                                Record Sale
                            </a>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<!-- Image Carousel Modal -->
<div id="imageCarouselModal" class="hidden fixed inset-0 z-50">
    <!-- Overlay -->
    <div id="carouselModalOverlay" class="fixed inset-0 bg-black bg-opacity-50"></div>
    
    <!-- Modal Container -->
    <div class="fixed inset-0 z-50 overflow-y-auto">
        <div class="flex min-h-full items-center justify-center p-6">
            <!-- Modal Content -->
            <div id="carouselModalContent" class="relative bg-gray-800 rounded-lg shadow-2xl w-full max-w-5xl transform transition-all opacity-0 scale-95">
                <!-- Header -->
                <div class="flex items-center justify-between p-3 border-b border-gray-600">
                    <h3 id="carouselTitle" class="text-lg font-semibold text-white">Vehicle Images</h3>
                    <button type="button" onclick="closeImageCarousel()" class="text-gray-400 hover:text-white transition-colors">
                        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>

                <!-- Carousel Container -->
                <div class="relative bg-gray-800">
                    <!-- Main Image Display -->
                    <div class="relative h-96 lg:h-[500px] overflow-hidden">
                        <div id="carouselMainImage" class="w-full h-full flex items-center justify-center">
                            <!-- Main image will be loaded here -->
                        </div>
                        
                        <!-- Navigation Arrows -->
                        <button id="carouselPrev" class="absolute left-4 top-1/2 transform -translate-y-1/2 bg-gray-700/80 hover:bg-gray-600 text-white p-3 rounded-full transition-all duration-200 opacity-100 shadow-lg">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                            </svg>
                        </button>
                        <button id="carouselNext" class="absolute right-4 top-1/2 transform -translate-y-1/2 bg-gray-700/80 hover:bg-gray-600 text-white p-3 rounded-full transition-all duration-200 opacity-100 shadow-lg">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </button>
                        
                        <!-- Image Counter -->
                        <div class="absolute bottom-4 right-4 bg-gray-700/80 backdrop-blur-sm text-white px-3 py-1 rounded-full text-sm font-medium shadow-lg">
                            <span id="carouselCounter">1</span>/<span id="carouselTotal">1</span>
                        </div>
                    </div>
                    
                    <!-- Thumbnail Navigation -->
                    <div class="p-3 bg-gray-700">
                        <div id="carouselThumbnails" class="flex space-x-2 overflow-x-auto pb-1">
                            <!-- Thumbnails will be loaded here -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Image Carousel Modal Functions
// Use a namespace to avoid variable conflicts with Turbo navigation
window.ImageCarousel = window.ImageCarousel || {
    currentImageIndex: 0,
    carouselImages: [],
    carouselBrand: ''
};

window.openImageCarousel = function(startIndex, images, brand) {
    console.log('openImageCarousel called with:', { startIndex, images, brand });
    window.ImageCarousel.currentImageIndex = startIndex;
    window.ImageCarousel.carouselImages = images;
    window.ImageCarousel.carouselBrand = brand;
    
    const modal = document.getElementById('imageCarouselModal');
    const overlay = document.getElementById('carouselModalOverlay');
    const content = document.getElementById('carouselModalContent');
    const title = document.getElementById('carouselTitle');
    const mainImage = document.getElementById('carouselMainImage');
    const thumbnails = document.getElementById('carouselThumbnails');
    const counter = document.getElementById('carouselCounter');
    const total = document.getElementById('carouselTotal');
    const prevBtn = document.getElementById('carouselPrev');
    const nextBtn = document.getElementById('carouselNext');

    console.log('Modal elements found:', { modal, overlay, content, title, mainImage, thumbnails, counter, total, prevBtn, nextBtn });

    if (!modal || !overlay || !content) {
        console.error('Required modal elements not found:', { modal, overlay, content });
        return;
    }

    // Set title
    if (title) title.textContent = `${brand} - Vehicle Images`;

    // Set total count
    if (total) total.textContent = images.length;

    // Load main image
    loadMainImage();

    // Load thumbnails
    loadThumbnails();

    // Show modal
    document.body.style.overflow = 'hidden';
    modal.classList.remove('hidden');
    
    // Fade in content
    requestAnimationFrame(() => {
        overlay.style.opacity = '0.5';
        content.classList.remove('opacity-0', 'scale-95');
        content.classList.add('opacity-100', 'scale-100');
    });

    // Add event listeners
    if (prevBtn) prevBtn.onclick = () => navigateCarousel(-1);
    if (nextBtn) nextBtn.onclick = () => navigateCarousel(1);

    // Keyboard navigation
    document.addEventListener('keydown', handleCarouselKeydown);
};

window.closeImageCarousel = function() {
    const modal = document.getElementById('imageCarouselModal');
    const overlay = document.getElementById('carouselModalOverlay');
    const content = document.getElementById('carouselModalContent');

    if (!modal || !overlay || !content) return;

    // Animate out
    content.classList.remove('opacity-100', 'scale-100');
    content.classList.add('opacity-0', 'scale-95');
    overlay.style.transition = 'opacity 200ms ease-out';
    overlay.style.opacity = '0';

    // Hide modal after animation
    setTimeout(() => {
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
        overlay.style.transition = '';
        overlay.style.opacity = '';
        
        // Clean up
        window.ImageCarousel.carouselImages = [];
        window.ImageCarousel.currentImageIndex = 0;
        document.removeEventListener('keydown', handleCarouselKeydown);
    }, 200);
};

function loadMainImage() {
    const mainImage = document.getElementById('carouselMainImage');
    const counter = document.getElementById('carouselCounter');
    
    if (!mainImage || !window.ImageCarousel.carouselImages.length) return;

    const imagePath = `/uploads/cars/${window.ImageCarousel.carouselImages[window.ImageCarousel.currentImageIndex]}`;
    mainImage.innerHTML = `
        <img src="${imagePath}" 
             alt="${window.ImageCarousel.carouselBrand} - Image ${window.ImageCarousel.currentImageIndex + 1}" 
             class="max-w-full max-h-full object-contain rounded-lg shadow-2xl"
             style="max-height: 100%; max-width: 100%;">
    `;

    if (counter) counter.textContent = window.ImageCarousel.currentImageIndex + 1;
}

function loadThumbnails() {
    const thumbnails = document.getElementById('carouselThumbnails');
    if (!thumbnails || !window.ImageCarousel.carouselImages.length) return;

    thumbnails.innerHTML = '';
    window.ImageCarousel.carouselImages.forEach((image, index) => {
        const thumbnail = document.createElement('button');
        thumbnail.className = `flex-shrink-0 w-16 h-12 rounded-lg overflow-hidden border-2 transition-all duration-200 shadow-lg ${
            index === window.ImageCarousel.currentImageIndex 
                ? 'border-white shadow-white/50' 
                : 'border-transparent hover:border-gray-400'
        }`;
        thumbnail.onclick = () => {
            window.ImageCarousel.currentImageIndex = index;
            loadMainImage();
            updateThumbnailSelection();
        };
        
        thumbnail.innerHTML = `
            <img src="/uploads/cars/${image}" 
                 alt="Thumbnail ${index + 1}" 
                 class="w-full h-full object-cover">
        `;
        
        thumbnails.appendChild(thumbnail);
    });
}

function updateThumbnailSelection() {
    const thumbnails = document.getElementById('carouselThumbnails');
    if (!thumbnails) return;

    const thumbnailButtons = thumbnails.querySelectorAll('button');
    thumbnailButtons.forEach((btn, index) => {
        if (index === window.ImageCarousel.currentImageIndex) {
            btn.classList.remove('border-transparent', 'hover:border-gray-400');
            btn.classList.add('border-white', 'shadow-white/50');
        } else {
            btn.classList.remove('border-white', 'shadow-white/50');
            btn.classList.add('border-transparent', 'hover:border-gray-400');
        }
    });
}

function navigateCarousel(direction) {
    if (!window.ImageCarousel.carouselImages.length) return;

    window.ImageCarousel.currentImageIndex += direction;
    
    // Loop around
    if (window.ImageCarousel.currentImageIndex < 0) {
        window.ImageCarousel.currentImageIndex = window.ImageCarousel.carouselImages.length - 1;
    } else if (window.ImageCarousel.currentImageIndex >= window.ImageCarousel.carouselImages.length) {
        window.ImageCarousel.currentImageIndex = 0;
    }

    loadMainImage();
    updateThumbnailSelection();
}

function handleCarouselKeydown(e) {
    switch(e.key) {
        case 'Escape':
            closeImageCarousel();
            break;
        case 'ArrowLeft':
            navigateCarousel(-1);
            break;
        case 'ArrowRight':
            navigateCarousel(1);
            break;
    }
}

// Close modal on overlay click and handle image clicks
// Use Turbo events for proper navigation handling
document.addEventListener('turbo:load', function() {
    const overlay = document.getElementById('carouselModalOverlay');
    if (overlay) {
        overlay.addEventListener('click', closeImageCarousel);
    }
});

// Handle carousel image clicks - use event delegation for better Turbo compatibility
document.addEventListener('click', function(e) {
    if (e.target.classList.contains('carousel-image')) {
        console.log('Image clicked:', e.target);
        const imageIndex = parseInt(e.target.getAttribute('data-image-index'));
        const images = JSON.parse(e.target.getAttribute('data-images'));
        const brand = e.target.getAttribute('data-brand');
        console.log('Opening carousel with:', { imageIndex, images, brand });
        openImageCarousel(imageIndex, images, brand);
    }
});
</script>
