{% extends 'base.html.twig' %}

{% block title %}Reports & Analytics{% endblock %}

{% block body %}
<div class="space-y-8" data-controller="reports" data-reports-charts-value="{{ chartData|json_encode|e('html_attr') }}">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div>
            <p class="text-sm uppercase tracking-wider text-gray-400">Executive Reports</p>
            <h1 class="text-3xl font-bold text-white mt-1">Business Performance & Sales</h1>
            <p class="text-gray-400 mt-2">Full-funnel visibility across sales, inventory, services, and documents.</p>
        </div>
        <div class="flex flex-wrap items-center gap-3">
            <div class="bg-gray-800 border border-gray-700 rounded-xl px-4 py-3">
                <div class="text-xs text-gray-400">Reporting window</div>
                <div class="text-sm font-semibold text-white">Year-to-date</div>
            </div>
            <div class="bg-gray-800 border border-gray-700 rounded-xl px-4 py-3">
                <div class="text-xs text-gray-400">Last sync</div>
                <div class="text-sm font-semibold text-white">{{ "now"|date("M d, Y H:i") }}</div>
            </div>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {% if is_granted('ROLE_ADMIN') %}
        <div class="bg-gradient-to-br from-emerald-500/20 to-emerald-700/20 border border-emerald-600/40 rounded-2xl p-5 shadow-lg">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-sm text-gray-300">Total Revenue</p>
                    <p class="text-3xl font-bold text-white mt-1">₱{{ (salesStats.total_revenue ?? 0)|number_format(2, '.', ',') }}</p>
                    <p class="text-xs text-emerald-300 mt-2">Growth {{ (salesStats.revenue_growth ?? 0)|number_format(1) }}% vs last month</p>
                </div>
                <span class="bg-emerald-600/30 text-emerald-200 px-3 py-1 rounded-full text-xs">Sales</span>
            </div>
        </div>

        <div class="bg-gradient-to-br from-blue-500/20 to-blue-700/20 border border-blue-600/40 rounded-2xl p-5 shadow-lg">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-sm text-gray-300">Monthly Revenue</p>
                    <p class="text-3xl font-bold text-white mt-1">₱{{ (salesStats.monthly_revenue ?? 0)|number_format(2, '.', ',') }}</p>
                    <p class="text-xs text-blue-300 mt-2">Average sale ₱{{ (salesStats.average_sale_price ?? 0)|number_format(0) }}</p>
                </div>
                <span class="bg-blue-600/30 text-blue-200 px-3 py-1 rounded-full text-xs">This Month</span>
            </div>
        </div>

        <div class="bg-gradient-to-br from-purple-500/20 to-purple-700/20 border border-purple-600/40 rounded-2xl p-5 shadow-lg">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-sm text-gray-300">Conversion Rate</p>
                    <p class="text-3xl font-bold text-white mt-1">{{ (salesStats.conversion_rate ?? 0)|number_format(1) }}%</p>
                    <p class="text-xs text-purple-200 mt-2">Pipeline health & closure velocity</p>
                </div>
                <span class="bg-purple-600/30 text-purple-200 px-3 py-1 rounded-full text-xs">Pipeline</span>
            </div>
        </div>
        {% endif %}

        <div class="bg-gradient-to-br from-amber-500/15 to-amber-700/20 border border-amber-600/30 rounded-2xl p-5 shadow-lg">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-sm text-gray-300">Inventory Value</p>
                    <p class="text-3xl font-bold text-white mt-1">₱{{ (inventoryTotals.value ?? 0)|number_format(2, '.', ',') }}</p>
                    <p class="text-xs text-amber-200 mt-2">{{ inventoryTotals.total ?? 0 }} vehicles • {{ inventoryTotals.available ?? 0 }} available</p>
                </div>
                <span class="bg-amber-600/30 text-amber-100 px-3 py-1 rounded-full text-xs">Inventory</span>
            </div>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
        <div class="bg-gradient-to-br from-cyan-500/15 to-cyan-700/20 border border-cyan-600/30 rounded-2xl p-5 shadow-lg">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-sm text-gray-300">Service Revenue</p>
                    <p class="text-3xl font-bold text-white mt-1">₱{{ (serviceStats.total_revenue ?? 0)|number_format(2, '.', ',') }}</p>
                    <p class="text-xs text-cyan-200 mt-2">{{ serviceStats.completed_services ?? 0 }} completed • {{ serviceStats.in_progress_services ?? 0 }} in progress</p>
                </div>
                <span class="bg-cyan-600/30 text-cyan-100 px-3 py-1 rounded-full text-xs">Service</span>
            </div>
        </div>
        {% endif %}

        <div class="bg-gradient-to-br from-rose-500/15 to-rose-700/20 border border-rose-600/30 rounded-2xl p-5 shadow-lg">
            <div class="flex items-start justify-between">
                <div>
                    <p class="text-sm text-gray-300">Documents Managed</p>
                    <p class="text-3xl font-bold text-white mt-1">{{ documentsTotal ?? 0 }}</p>
                    <p class="text-xs text-rose-200 mt-2">Compliance coverage & digital paperwork</p>
                </div>
                <span class="bg-rose-600/30 text-rose-100 px-3 py-1 rounded-full text-xs">Documents</span>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
        <div class="xl:col-span-2 bg-gray-900/80 border border-gray-800 rounded-2xl p-5 shadow-xl">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <p class="text-sm text-gray-400">Revenue + Volume</p>
                    <h3 class="text-xl font-semibold text-white">Sales Trend (12 months)</h3>
                </div>
                <div class="text-right">
                    <p class="text-gray-400 text-xs">Top Brand</p>
                    <p class="text-sm font-semibold text-white">{{ salesStats.top_brand ?? '—' }}</p>
                </div>
            </div>
            <div class="h-72">
                <canvas data-reports-target="salesTrend"></canvas>
            </div>
        </div>

        <div class="bg-gray-900/80 border border-gray-800 rounded-2xl p-5 shadow-xl">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <p class="text-sm text-gray-400">Pipeline Status</p>
                    <h3 class="text-xl font-semibold text-white">Sales Funnel</h3>
                </div>
                <span class="text-xs text-gray-300 bg-gray-800 px-3 py-1 rounded-full border border-gray-700">Live</span>
            </div>
            <div class="h-72">
                <canvas data-reports-target="pipeline"></canvas>
            </div>
        </div>
    </div>

    <!-- Charts Row 2 -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
        <div class="bg-gray-900/80 border border-gray-800 rounded-2xl p-5 shadow-xl">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <p class="text-sm text-gray-400">Brand Performance</p>
                    <h3 class="text-xl font-semibold text-white">Top 5 Brands (last 6 months)</h3>
                </div>
                <span class="text-xs text-gray-300 bg-gray-800 px-3 py-1 rounded-full border border-gray-700">Sales & revenue</span>
            </div>
            <div class="h-72">
                <canvas data-reports-target="topBrands"></canvas>
            </div>
        </div>

        <div class="bg-gray-900/80 border border-gray-800 rounded-2xl p-5 shadow-xl">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <p class="text-sm text-gray-400">Vehicle Readiness</p>
                    <h3 class="text-xl font-semibold text-white">Inventory Condition Mix</h3>
                </div>
                <span class="text-xs text-gray-300 bg-gray-800 px-3 py-1 rounded-full border border-gray-700">{{ inventoryTotals.total ?? 0 }} units</span>
            </div>
            <div class="h-72">
                <canvas data-reports-target="inventory"></canvas>
            </div>
        </div>

        <div class="bg-gray-900/80 border border-gray-800 rounded-2xl p-5 shadow-xl">
            <div class="flex items-center justify-between mb-4">
                <div>
                    <p class="text-sm text-gray-400">Operations</p>
                    <h3 class="text-xl font-semibold text-white">Service & Documents</h3>
                </div>
                <span class="text-xs text-gray-300 bg-gray-800 px-3 py-1 rounded-full border border-gray-700">Health</span>
            </div>
            <div class="grid grid-cols-1 gap-6">
                <div class="h-32">
                    <canvas data-reports-target="service"></canvas>
                </div>
                <div class="h-32">
                    <canvas data-reports-target="documents"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Sales -->
    <div class="bg-gray-900/80 border border-gray-800 rounded-2xl p-5 shadow-xl">
        <div class="flex items-center justify-between mb-4">
            <div>
                <p class="text-sm text-gray-400">Velocity</p>
                <h3 class="text-xl font-semibold text-white">Recent Sales</h3>
            </div>
            <a href="{{ path('app_sales_index') ?? '#' }}" class="text-sm text-[#B32224] hover:text-red-400">View all</a>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full text-sm text-left">
                <thead class="text-gray-400 uppercase tracking-wide border-b border-gray-800">
                    <tr>
                        <th class="py-3 pr-4">Date</th>
                        <th class="py-3 pr-4">Customer</th>
                        <th class="py-3 pr-4">Vehicle</th>
                        <th class="py-3 pr-4">Status</th>
                        <th class="py-3 pr-4 text-right">Sale Price</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800">
                    {% for sale in recentSales %}
                        <tr class="text-gray-200">
                            <td class="py-3 pr-4">{{ sale.saleDate ? sale.saleDate|date('M d, Y') : '—' }}</td>
                            <td class="py-3 pr-4">{{ sale.customer ? sale.customer.firstName ~ ' ' ~ sale.customer.lastName : '—' }}</td>
                            <td class="py-3 pr-4">
                                {% if sale.vehicle %}
                                    {{ sale.vehicle.brand }} {{ sale.vehicle.year }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td class="py-3 pr-4">
                                <span class="px-3 py-1 rounded-full text-xs border 
                                    {% if sale.status == 'completed' %}border-emerald-500 text-emerald-300 bg-emerald-500/10
                                    {% elseif sale.status == 'pending' %}border-amber-500 text-amber-300 bg-amber-500/10
                                    {% else %}border-gray-600 text-gray-300 bg-gray-700/30{% endif %}">
                                    {{ sale.status|capitalize }}
                                </span>
                            </td>
                            <td class="py-3 pr-4 text-right font-semibold">₱{{ sale.salePrice|number_format(2, '.', ',') }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="py-4 text-center text-gray-400">No sales recorded yet.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}
