{% extends 'base.html.twig' %}

{% block title %}Reports & Analytics{% endblock %}

{% block body %}
    <!-- Header Section -->
    <div class="mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
            </div>
        </div>
    </div>

    <!-- Coming Soon Content -->
    <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
        <!-- Coming Soon Icon -->
        <div class="mb-8">
            <div class="relative">
                <div class="w-32 h-32 bg-gradient-to-br from-blue-500 to-blue-800 rounded-full flex items-center justify-center shadow-2xl">
                    <svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                </div>
                <!-- Animated pulse ring -->
                <div class="absolute inset-0 w-32 h-32 bg-blue-500 rounded-full animate-ping opacity-20"></div>
            </div>
        </div>

        <!-- Coming Soon Text -->
        <div class="max-w-2xl mx-auto">
            <h2 class="text-4xl font-bold text-gray-100 mb-4">Coming Soon</h2>
            <p class="text-xl text-gray-300 mb-6">
                Advanced reporting and analytics tools are being developed to give you deep insights into your dealership's performance.
            </p>
            
            <!-- Features Preview -->
            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700 mb-8">
                <h3 class="text-lg font-semibold text-gray-100 mb-4">What to Expect:</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-left">
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                        <span class="text-gray-300">Sales Performance Reports</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                        <span class="text-gray-300">Inventory Analytics</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                        <span class="text-gray-300">Customer Insights</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                        <span class="text-gray-300">Financial Dashboards</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                        <span class="text-gray-300">Trend Analysis</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                        <span class="text-gray-300">Export to PDF/Excel</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                        <span class="text-gray-300">Custom Report Builder</span>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                        <span class="text-gray-300">Scheduled Reports</span>
                    </div>
                </div>
            </div>

            <!-- Progress Indicator -->
            <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-gray-300 font-medium">Development Progress</span>
                    <span class="text-blue-500 font-semibold">60%</span>
                </div>
                <div class="w-full bg-gray-700 rounded-full h-3">
                    <div class="bg-gradient-to-r from-blue-500 to-blue-600 h-3 rounded-full transition-all duration-1000 ease-out" style="width: 60%"></div>
                </div>
                <p class="text-sm text-gray-400 mt-2">Expected completion: AFTER MIDTERM</p>
            </div>

            <!-- Quick Stats Preview -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-8">
                <div class="bg-gray-800 rounded-xl p-4 border border-gray-700">
                    <div class="text-2xl font-bold text-blue-400 mb-1">15+</div>
                    <div class="text-sm text-gray-400">Report Types</div>
                </div>
                <div class="bg-gray-800 rounded-xl p-4 border border-gray-700">
                    <div class="text-2xl font-bold text-green-400 mb-1">Real-time</div>
                    <div class="text-sm text-gray-400">Data Updates</div>
                </div>
                <div class="bg-gray-800 rounded-xl p-4 border border-gray-700">
                    <div class="text-2xl font-bold text-purple-400 mb-1">Custom</div>
                    <div class="text-sm text-gray-400">Dashboards</div>
                </div>
            </div>

            <!-- Back to Dashboard -->
            <div class="mt-8">
                <a href="{{ path('app_dashboard') }}" 
                   class="inline-flex items-center px-6 py-3 bg-[#B32224] hover:bg-red-700 text-white rounded-xl font-medium transition-all duration-200 hover:scale-105 shadow-lg hover:shadow-xl">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                    </svg>
                    Back to Dashboard
                </a>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Add some subtle animations
    document.addEventListener('DOMContentLoaded', function() {
        // Animate progress bar on load
        const progressBar = document.querySelector('.bg-gradient-to-r');
        if (progressBar) {
            setTimeout(() => {
                progressBar.style.width = '60%';
            }, 500);
        }
    });
</script>
{% endblock %}
