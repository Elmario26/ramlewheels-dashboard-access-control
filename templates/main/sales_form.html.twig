{% extends 'base.html.twig' %}

{% block title %}{{ sale.id ? 'Edit Sale' : 'Record New Sale' }}{% endblock %}

{% block body %}

    <div class="max-w-4xl mx-auto">
        <!-- Header Section -->
        <div class="mb-8">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-gray-100">
                        {{ sale.id ? 'Edit Sale' : 'Record New Sale' }}
                    </h1>
                    <p class="mt-2 text-gray-400">
                        {{ sale.id ? 'Update sale information' : 'Record a new vehicle sale' }}
                    </p>
                </div>
                <a href="{{ path('app_sales_index') }}" 
                   class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition-colors duration-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                    </svg>
                    Back to Sales
                </a>
            </div>
        </div>

        <!-- Form Section -->
        <div class="bg-gray-800 rounded-xl shadow-lg p-8 border border-gray-700">
            {{ form_start(form, {'attr': {'class': 'space-y-6', 'id': 'salesForm'}}) }}
            
            <!-- Progress Indicator -->
            <div class="mb-8">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium text-gray-300">Form Progress</span>
                    <span class="text-sm text-gray-400" id="progressText">0% Complete</span>
                </div>
                <div class="w-full bg-gray-700 rounded-full h-2">
                    <div class="bg-[#B32224] h-2 rounded-full transition-all duration-300" id="progressBar" style="width: 0%"></div>
                </div>
            </div>
            
            <!-- Vehicle Selection -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="lg:col-span-2">
                    <label class="block text-sm font-medium text-gray-300 mb-2">
                        Vehicle *
                        <span class="text-red-400" id="vehicle-error" style="display: none;">Required</span>
                    </label>
                    {{ form_widget(form.vehicle, {'attr': {'class': 'w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-gray-100 focus:ring-2 focus:ring-[#B32224] focus:border-transparent transition-all duration-200', 'data-field': 'vehicle'}}) }}
                    {{ form_errors(form.vehicle) }}
                    <div class="mt-2 text-xs text-gray-400" id="vehicle-info" style="display: none;">
                        <div class="flex items-center">
                            <svg class="w-4 h-4 mr-1 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                            Vehicle selected
                        </div>
                    </div>
                </div>
            </div>

            <!-- Customer Selection -->
            <div class="border-t border-gray-700 pt-6">
                <h3 class="text-lg font-semibold text-gray-100 mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-[#B32224]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    Customer Selection
                </h3>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div class="lg:col-span-2">
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            Select Customer *
                            <span class="text-red-400" id="customer-error" style="display: none;">Required</span>
                        </label>
                        <div class="relative">
                            {{ form_widget(form.customer, {'attr': {'class': 'w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-gray-100 focus:ring-2 focus:ring-[#B32224] focus:border-transparent transition-all duration-200', 'data-controller': 'customer-select', 'data-field': 'customer'}}) }}
                            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                </svg>
                            </div>
                        </div>
                        {{ form_errors(form.customer) }}
                        <div class="mt-2 text-xs text-gray-400" id="customer-info" style="display: none;">
                            <div class="flex items-center">
                                <svg class="w-4 h-4 mr-1 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                                Customer selected
                            </div>
                        </div>
                        <p class="mt-1 text-xs text-gray-400">Choose from registered customers or add a new customer first</p>
                    </div>
                </div>
                
                <!-- Customer Details Display (Hidden by default) -->
                <div id="customerDetails" class="mt-4 p-4 bg-gray-700 rounded-lg border border-gray-600 hidden">
                    <h4 class="text-sm font-medium text-gray-300 mb-3">Customer Information</h4>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <span class="text-xs text-gray-400">Name:</span>
                            <p id="customerName" class="text-sm text-gray-100"></p>
                        </div>
                        <div>
                            <span class="text-xs text-gray-400">Email:</span>
                            <p id="customerEmail" class="text-sm text-gray-100"></p>
                        </div>
                        <div>
                            <span class="text-xs text-gray-400">Phone:</span>
                            <p id="customerPhone" class="text-sm text-gray-100"></p>
                        </div>
                        <div>
                            <span class="text-xs text-gray-400">Address:</span>
                            <p id="customerAddress" class="text-sm text-gray-100"></p>
                        </div>
                    </div>
                </div>
                
                <!-- Customer Management Link -->
                <div class="mt-4 flex items-center justify-end">
                    <a href="{{ path('app_customers_new') }}" target="_blank" class="text-sm text-gray-400 hover:text-gray-200 transition-colors duration-200">
                        <svg class="w-4 h-4 mr-1 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                        Add New Customer
                    </a>
                </div>
            </div>

            <!-- Sale Information -->
            <div class="border-t border-gray-700 pt-6">
                <h3 class="text-lg font-semibold text-gray-100 mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-[#B32224]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Sale Information
                </h3>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            Sale Price *
                            <span class="text-red-400" id="salePrice-error" style="display: none;">Required</span>
                        </label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400">₱</span>
                            {{ form_widget(form.salePrice, {'attr': {'class': 'w-full pl-8 pr-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-gray-100 focus:ring-2 focus:ring-[#B32224] focus:border-transparent transition-all duration-200', 'data-field': 'salePrice', 'placeholder': '0.00'}}) }}
                        </div>
                        {{ form_errors(form.salePrice) }}
                        <div class="mt-2 text-xs text-gray-400" id="salePrice-info" style="display: none;">
                            <div class="flex items-center">
                                <svg class="w-4 h-4 mr-1 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                                Valid price entered
                            </div>
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            Down Payment
                        </label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400">₱</span>
                            {{ form_widget(form.downPayment, {'attr': {'class': 'w-full pl-8 pr-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-gray-100 focus:ring-2 focus:ring-[#B32224] focus:border-transparent transition-all duration-200', 'data-field': 'downPayment', 'placeholder': '0.00'}}) }}
                        </div>
                        {{ form_errors(form.downPayment) }}
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            Financing Amount
                            <span class="text-blue-400 text-xs">(Auto-calculated)</span>
                        </label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400">₱</span>
                            {{ form_widget(form.financingAmount, {'attr': {'class': 'w-full pl-8 pr-4 py-3 bg-gray-600 border border-gray-600 rounded-lg text-gray-300 focus:ring-2 focus:ring-[#B32224] focus:border-transparent transition-all duration-200', 'readonly': 'readonly', 'data-field': 'financingAmount'}}) }}
                        </div>
                        {{ form_errors(form.financingAmount) }}
                        <div class="mt-2 text-xs text-gray-400">
                            <div class="flex items-center">
                                <svg class="w-4 h-4 mr-1 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                Calculated as Sale Price - Down Payment
                            </div>
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            Payment Method
                        </label>
                        {{ form_widget(form.paymentMethod, {'attr': {'class': 'w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-gray-100 focus:ring-2 focus:ring-[#B32224] focus:border-transparent transition-all duration-200', 'data-field': 'paymentMethod'}}) }}
                        {{ form_errors(form.paymentMethod) }}
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            Sale Date *
                            <span class="text-red-400" id="saleDate-error" style="display: none;">Required</span>
                        </label>
                        {{ form_widget(form.saleDate, {'attr': {'class': 'w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-gray-100 focus:ring-2 focus:ring-[#B32224] focus:border-transparent transition-all duration-200', 'data-field': 'saleDate'}}) }}
                        {{ form_errors(form.saleDate) }}
                        <div class="mt-2 text-xs text-gray-400" id="saleDate-info" style="display: none;">
                            <div class="flex items-center">
                                <svg class="w-4 h-4 mr-1 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                                Date selected
                            </div>
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">
                            Status *
                            <span class="text-red-400" id="status-error" style="display: none;">Required</span>
                        </label>
                        {{ form_widget(form.status, {'attr': {'class': 'w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-gray-100 focus:ring-2 focus:ring-[#B32224] focus:border-transparent transition-all duration-200', 'data-field': 'status'}}) }}
                        {{ form_errors(form.status) }}
                        <div class="mt-2 text-xs text-gray-400" id="status-info" style="display: none;">
                            <div class="flex items-center">
                                <svg class="w-4 h-4 mr-1 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                                Status selected
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Additional Notes -->
            <div class="border-t border-gray-700 pt-6">
                <h3 class="text-lg font-semibold text-gray-100 mb-4">Additional Information</h3>
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">
                        Notes
                    </label>
                    {{ form_widget(form.notes, {'attr': {'class': 'w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded-lg text-gray-100 focus:ring-2 focus:ring-[#B32224] focus:border-transparent transition-all duration-200'}}) }}
                    {{ form_errors(form.notes) }}
                </div>
            </div>

            <!-- Form Actions -->
            <div class="border-t border-gray-700 pt-6 flex justify-end space-x-4">
                <a href="{{ path('app_sales_index') }}" 
                   class="px-6 py-3 bg-gray-700 hover:bg-gray-600 text-gray-100 rounded-lg font-medium transition-colors duration-200">
                    Cancel
                </a>
                <button type="submit" 
                        class="px-6 py-3 bg-[#B32224] hover:bg-red-700 text-white rounded-lg font-medium transition-colors duration-200 hover:scale-105 shadow-lg">
                    {{ sale.id ? 'Update Sale' : 'Record Sale' }}
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Wait for DOM to be fully loaded before executing JavaScript
    document.addEventListener('DOMContentLoaded', function() {
        // Enhanced form validation and progress tracking
        const salePriceInput = document.querySelector('input[name="sales[salePrice]"]');
        const downPaymentInput = document.querySelector('input[name="sales[downPayment]"]');
        const financingAmountInput = document.querySelector('input[name="sales[financingAmount]"]');
        const vehicleSelect = document.querySelector('select[name="sales[vehicle]"]');
        const customerSelect = document.querySelector('select[name="sales[customer]"]');
        const saleDateInput = document.querySelector('input[name="sales[saleDate]"]');
        const statusSelect = document.querySelector('select[name="sales[status]"]');
        
        // Progress tracking
        const progressBar = document.getElementById('progressBar');
        const progressText = document.getElementById('progressText');
        
        function updateProgress() {
            let completed = 0;
            const total = 6; // Total required fields
            
            if (vehicleSelect && vehicleSelect.value) completed++;
            if (customerSelect && customerSelect.value) completed++;
            if (salePriceInput && salePriceInput.value && parseFloat(salePriceInput.value) > 0) completed++;
            if (saleDateInput && saleDateInput.value) completed++;
            if (statusSelect && statusSelect.value) completed++;
            if (downPaymentInput && downPaymentInput.value) completed++;
            
            const percentage = Math.round((completed / total) * 100);
            if (progressBar) {
                progressBar.style.width = percentage + '%';
            }
            if (progressText) {
                progressText.textContent = percentage + '% Complete';
            }
        }
        
        // Real-time validation
        function validateField(field, errorId, infoId) {
            const errorEl = document.getElementById(errorId);
            const infoEl = document.getElementById(infoId);
            
            if (field && field.value && field.value.trim() !== '') {
                if (errorEl) errorEl.style.display = 'none';
                if (infoEl) infoEl.style.display = 'block';
                field.classList.remove('border-red-500');
                field.classList.add('border-green-500');
                return true;
            } else {
                if (errorEl) errorEl.style.display = 'inline';
                if (infoEl) infoEl.style.display = 'none';
                field.classList.remove('border-green-500');
                field.classList.add('border-red-500');
                return false;
            }
        }
        
        function calculateFinancing() {
            if (salePriceInput && downPaymentInput && financingAmountInput) {
                const salePrice = parseFloat(salePriceInput.value) || 0;
                const downPayment = parseFloat(downPaymentInput.value) || 0;
                const financing = salePrice - downPayment;
                
                if (financing > 0) {
                    financingAmountInput.value = financing.toFixed(2);
                } else {
                    financingAmountInput.value = '';
                }
                updateProgress();
            }
        }
        
        // Add event listeners for real-time validation
        if (vehicleSelect) {
            vehicleSelect.addEventListener('change', function() {
                validateField(this, 'vehicle-error', 'vehicle-info');
                updateProgress();
            });
        }
        
        if (customerSelect) {
            customerSelect.addEventListener('change', function() {
                validateField(this, 'customer-error', 'customer-info');
                updateProgress();
            });
        }
        
        if (salePriceInput) {
            salePriceInput.addEventListener('input', function() {
                validateField(this, 'salePrice-error', 'salePrice-info');
                calculateFinancing();
                updateProgress();
            });
        }
        
        if (downPaymentInput) {
            downPaymentInput.addEventListener('input', function() {
                calculateFinancing();
                updateProgress();
            });
        }
        
        if (saleDateInput) {
            saleDateInput.addEventListener('change', function() {
                validateField(this, 'saleDate-error', 'saleDate-info');
                updateProgress();
            });
        }
        
        if (statusSelect) {
            statusSelect.addEventListener('change', function() {
                validateField(this, 'status-error', 'status-info');
                updateProgress();
            });
        }
        
        // Initial progress calculation
        updateProgress();

        // Customer selection functionality
        const customerDetails = document.getElementById('customerDetails');
        
        if (customerSelect && customerDetails) {
            customerSelect.addEventListener('change', function() {
                const selectedCustomerId = this.value;
                
                if (selectedCustomerId) {
                    // Show loading state
                    if (customerDetails) {
                        customerDetails.classList.add('hidden');
                    }
                    
                    // Fetch customer details via AJAX
                    fetch(`/customers/${selectedCustomerId}/details`, {
                        method: 'GET',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'Content-Type': 'application/json'
                        }
                    })
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.json();
                    })
                       .then(data => {
                           if (data && data.success && data.customer) {
                               // Safely update customer details
                               const customerNameEl = document.getElementById('customerName');
                               const customerEmailEl = document.getElementById('customerEmail');
                               const customerPhoneEl = document.getElementById('customerPhone');
                               const customerAddressEl = document.getElementById('customerAddress');
                               
                               if (customerNameEl) customerNameEl.textContent = data.customer.fullName || 'N/A';
                               if (customerEmailEl) customerEmailEl.textContent = data.customer.email || 'N/A';
                               if (customerPhoneEl) customerPhoneEl.textContent = data.customer.phone ? '+63 ' + data.customer.phone : 'N/A';
                               if (customerAddressEl) customerAddressEl.textContent = data.customer.address || 'N/A';
                               
                               // Show customer details
                               if (customerDetails) {
                                   customerDetails.classList.remove('hidden');
                               }
                           }
                       })
                    .catch(error => {
                        console.error('Error fetching customer details:', error);
                        if (customerDetails) {
                            customerDetails.classList.add('hidden');
                        }
                    });
                } else {
                    if (customerDetails) {
                        customerDetails.classList.add('hidden');
                    }
                }
            });
        }

        // Form submission handler
        const form = document.getElementById('salesForm');
        if (form) {
            form.addEventListener('submit', function(e) {
                let isValid = true;
                let firstInvalidField = null;
                
                // Validate all required fields
                const requiredFields = [
                    { field: vehicleSelect, name: 'Vehicle' },
                    { field: customerSelect, name: 'Customer' },
                    { field: salePriceInput, name: 'Sale Price' },
                    { field: saleDateInput, name: 'Sale Date' },
                    { field: statusSelect, name: 'Status' }
                ];
                
                requiredFields.forEach(({ field, name }) => {
                    if (!field || !field.value || field.value.trim() === '') {
                        isValid = false;
                        if (!firstInvalidField) firstInvalidField = field;
                        
                        // Show error
                        const errorId = field.getAttribute('data-field') + '-error';
                        const errorEl = document.getElementById(errorId);
                        if (errorEl) errorEl.style.display = 'inline';
                        
                        field.classList.add('border-red-500');
                        field.classList.remove('border-green-500');
                    }
                });
                
                // Validate sale price is positive
                if (salePriceInput && salePriceInput.value) {
                    const price = parseFloat(salePriceInput.value);
                    if (price <= 0) {
                        isValid = false;
                        if (!firstInvalidField) firstInvalidField = salePriceInput;
                        
                        const errorEl = document.getElementById('salePrice-error');
                        if (errorEl) {
                            errorEl.textContent = 'Sale price must be greater than 0';
                            errorEl.style.display = 'inline';
                        }
                    }
                }
                
                if (!isValid) {
                    e.preventDefault();
                    
                    // Show validation summary
                    showGlobalResultModal('warning', 'Form Validation', 'Please complete all required fields before submitting.', {
                        buttons: [
                            {
                                text: 'OK',
                                class: 'px-4 py-2 bg-[#B32224] text-white rounded-lg hover:bg-red-700 transition-colors duration-200',
                                action: function() {
                                    closeGlobalResultModal();
                                    if (firstInvalidField) {
                                        firstInvalidField.focus();
                                        firstInvalidField.scrollIntoView({ behavior: 'smooth', block: 'center' });
                                    }
                                }
                            }
                        ]
                    });
                    return false;
                }

                // Disable submit button to prevent double submission
                const submitBtn = form.querySelector('button[type="submit"]');
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<svg class="animate-spin h-5 w-5 mr-2 inline-block" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Saving...';
                }
            });
        }
    });


    // Example: Show success message using global modal
    window.showSaleSuccess = function() {
        showGlobalResultModal('success', 'Sale Recorded!', 'The sale has been successfully recorded.', {
            buttons: [
                {
                    text: 'View Sales',
                    class: 'px-4 py-2 bg-[#B32224] border border-transparent rounded-md text-sm font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#B32224]',
                    action: function() {
                        closeGlobalResultModal();
                        window.location.href = '{{ path('app_sales_index') }}';
                    }
                },
                {
                    text: 'Add Another',
                    class: 'px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#B32224]',
                    action: function() {
                        closeGlobalResultModal();
                        window.location.reload();
                    }
                }
            ]
        });
    }; 
{% endblock %}
