{% extends 'base.html.twig' %}

{% block title %}Sale Details - {{ sale.customer.fullName }}{% endblock %}

{% block body %}
    <div class="max-w-6xl mx-auto">
        <!-- Header Section -->
        <div class="mb-8">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-gray-100">Sale Details</h1>
                    <p class="mt-2 text-gray-400">Sale #{{ sale.id }} - {{ sale.customer.fullName }}</p>
                </div>
                <div class="flex items-center gap-3">
                    {% if sale.status != 'completed' %}
                        <a href="{{ path('app_sales_edit', {'id': sale.id}) }}" 
                           class="bg-[#B32224] hover:bg-red-700 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition-colors duration-200">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                            </svg>
                            Edit Sale
                        </a>
                    {% endif %}
                    <a href="{{ path('app_sales_index') }}" 
                       class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition-colors duration-200">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                        </svg>
                        Back to Sales
                    </a>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Main Content -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Vehicle Information -->
                <div class="bg-gray-800 rounded-xl shadow-lg p-6 border border-gray-700">
                    <h3 class="text-lg font-semibold text-gray-100 mb-4 flex items-center">
                        <svg class="w-5 h-5 mr-2 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/>
                        </svg>
                        Vehicle Information
                    </h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Brand & Model</label>
                            <p class="text-lg font-semibold text-gray-100">{{ sale.vehicle.brand }}</p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Year</label>
                            <p class="text-lg font-semibold text-gray-100">{{ sale.vehicle.year }}</p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Mileage</label>
                            <p class="text-lg font-semibold text-gray-100">{{ sale.vehicle.mileage|number_format(0, '.', ',') }} km</p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Condition</label>
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium 
                                {% if sale.vehicle.conditions|lower == 'excellent' %}bg-green-100 text-green-800
                                {% elseif sale.vehicle.conditions|lower == 'good' %}bg-blue-100 text-blue-800
                                {% elseif sale.vehicle.conditions|lower == 'fair' %}bg-yellow-100 text-yellow-800
                                {% else %}bg-red-100 text-red-800{% endif %}">
                                {{ sale.vehicle.conditions }}
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Customer Information -->
                <div class="bg-gray-800 rounded-xl shadow-lg p-6 border border-gray-700">
                    <h3 class="text-lg font-semibold text-gray-100 mb-4 flex items-center">
                        <svg class="w-5 h-5 mr-2 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        Customer Information
                    </h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Name</label>
                            <p class="text-lg font-semibold text-gray-100">{{ sale.customer.fullName }}</p>
                        </div>
                        {% if sale.customer.email %}
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Email</label>
                            <p class="text-lg font-semibold text-gray-100">{{ sale.customer.email }}</p>
                        </div>
                        {% endif %}
                        {% if sale.customer.phone %}
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Phone</label>
                            <p class="text-lg font-semibold text-gray-100">{{ sale.customer.phone }}</p>
                        </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Sale Information -->
                <div class="bg-gray-800 rounded-xl shadow-lg p-6 border border-gray-700">
                    <h3 class="text-lg font-semibold text-gray-100 mb-4 flex items-center">
                        <svg class="w-5 h-5 mr-2 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Sale Information
                    </h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Sale Price</label>
                            <p class="text-2xl font-bold text-[#B32224]">₱{{ sale.salePrice|number_format(2, '.', ',') }}</p>
                        </div>
                        {% if sale.downPayment %}
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Down Payment</label>
                            <p class="text-lg font-semibold text-gray-100">₱{{ sale.downPayment|number_format(2, '.', ',') }}</p>
                        </div>
                        {% endif %}
                        {% if sale.financingAmount %}
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Financing Amount</label>
                            <p class="text-lg font-semibold text-gray-100">₱{{ sale.financingAmount|number_format(2, '.', ',') }}</p>
                        </div>
                        {% endif %}
                        {% if sale.paymentMethod %}
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Payment Method</label>
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-700 text-gray-300">
                                {{ sale.paymentMethod|title }}
                            </span>
                        </div>
                        {% endif %}
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Sale Date</label>
                            <p class="text-lg font-semibold text-gray-100">{{ sale.saleDate|date('F d, Y') }}</p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-400 mb-1">Status</label>
                            {% if sale.status == 'completed' %}
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                                    <svg class="w-2 h-2 mr-1" fill="currentColor" viewBox="0 0 8 8">
                                        <circle cx="4" cy="4" r="3"/>
                                    </svg>
                                    Completed
                                </span>
                            {% elseif sale.status == 'pending' %}
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
                                    <svg class="w-2 h-2 mr-1" fill="currentColor" viewBox="0 0 8 8">
                                        <circle cx="4" cy="4" r="3"/>
                                    </svg>
                                    Pending
                                </span>
                            {% else %}
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">
                                    <svg class="w-2 h-2 mr-1" fill="currentColor" viewBox="0 0 8 8">
                                        <circle cx="4" cy="4" r="3"/>
                                    </svg>
                                    Cancelled
                                </span>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <!-- Notes -->
                {% if sale.notes %}
                <div class="bg-gray-800 rounded-xl shadow-lg p-6 border border-gray-700">
                    <h3 class="text-lg font-semibold text-gray-100 mb-4 flex items-center">
                        <svg class="w-5 h-5 mr-2 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        Notes
                    </h3>
                    <p class="text-gray-300 leading-relaxed">{{ sale.notes }}</p>
                </div>
                {% endif %}
            </div>

            <!-- Sidebar -->
            <div class="space-y-6">
                <!-- Vehicle Image -->
                <div class="bg-gray-800 rounded-xl shadow-lg p-6 border border-gray-700">
                    <h3 class="text-lg font-semibold text-gray-100 mb-4">Vehicle Image</h3>
                    {% if sale.vehicle.images is not empty %}
                        <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-gray-900 to-gray-800 rounded-lg">
                            <img src="{{ asset('uploads/cars/' ~ sale.vehicle.images[0]) }}" 
                                 alt="{{ sale.vehicle.brand }}" 
                                 class="w-full h-full object-cover">
                        </div>
                    {% else %}
                        <div class="aspect-[4/3] bg-gradient-to-br from-gray-900 to-gray-800 rounded-lg flex items-center justify-center">
                            <div class="text-center text-gray-500">
                                <svg class="w-16 h-16 mx-auto mb-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                                <p class="text-sm font-medium">No image available</p>
                            </div>
                        </div>
                    {% endif %}
                </div>

                <!-- Financial Summary -->
                <div class="bg-gray-800 rounded-xl shadow-lg p-6 border border-gray-700">
                    <h3 class="text-lg font-semibold text-gray-100 mb-4">Financial Summary</h3>
                    
                    <div class="space-y-4">
                        <div class="flex justify-between items-center">
                            <span class="text-gray-400">Original Price:</span>
                            <span class="text-gray-300">₱{{ sale.vehicle.price|number_format(2, '.', ',') }}</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-400">Sale Price:</span>
                            <span class="text-[#B32224] font-semibold">₱{{ sale.salePrice|number_format(2, '.', ',') }}</span>
                        </div>
                        <div class="border-t border-gray-700 pt-4">
                            <div class="flex justify-between items-center">
                                <span class="text-gray-400">Profit:</span>
                                <span class="text-green-400 font-semibold">₱{{ sale.profit|number_format(2, '.', ',') }}</span>
                            </div>
                            <div class="flex justify-between items-center mt-2">
                                <span class="text-gray-400">Profit Margin:</span>
                                <span class="text-green-400 font-semibold">{{ sale.profitMargin|number_format(1) }}%</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sale Timeline -->
                <div class="bg-gray-800 rounded-xl shadow-lg p-6 border border-gray-700">
                    <h3 class="text-lg font-semibold text-gray-100 mb-4">Timeline</h3>
                    
                    <div class="space-y-3">
                        <div class="flex items-center">
                            <div class="w-2 h-2 bg-green-400 rounded-full mr-3"></div>
                            <div>
                                <p class="text-sm font-medium text-gray-100">Sale Created</p>
                                <p class="text-xs text-gray-400">{{ sale.createdAt|date('M d, Y H:i') }}</p>
                            </div>
                        </div>
                        {% if sale.updatedAt %}
                        <div class="flex items-center">
                            <div class="w-2 h-2 bg-blue-400 rounded-full mr-3"></div>
                            <div>
                                <p class="text-sm font-medium text-gray-100">Last Updated</p>
                                <p class="text-xs text-gray-400">{{ sale.updatedAt|date('M d, Y H:i') }}</p>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
