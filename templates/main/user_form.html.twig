{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <!-- Header Section -->
    <div class="mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold text-gray-100">{{ title }}</h1>
                <p class="mt-2 text-gray-400">
                    {% if user.id %}
                        Edit user information and permissions
                    {% else %}
                        Add a new user to the system
                    {% endif %}
                </p>
            </div>
            <div class="flex items-center gap-3">
                <a href="{{ path('app_users_index') }}" 
                   class="bg-gray-600 hover:bg-gray-700 text-white px-6 py-2.5 rounded-lg flex items-center gap-2 font-medium transition-all duration-200">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                    </svg>
                    Back to Users
                </a>
            </div>
        </div>
    </div>

    <!-- Form Section -->
    <div class="bg-gray-800 rounded-xl shadow-lg border border-gray-700">
        <div class="px-6 py-4 border-b border-gray-700">
            <h3 class="text-lg font-semibold text-white">User Information</h3>
        </div>
        
        <div class="p-6">
            {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
            
            <!-- Username Field (top priority) -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div>
                    {{ form_row(form.username) }}
                </div>
            </div>

            <!-- Basic Information Row -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div>
                    {{ form_row(form.firstName) }}
                </div>
                <div>
                    {{ form_row(form.lastName) }}
                </div>
            </div>

            <!-- Contact Information Row -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div>
                    {{ form_row(form.email) }}
                </div>
                <div>
                    {{ form_row(form.phone) }}
                </div>
            </div>

            <!-- Role and Status Row -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div>
                    {{ form_row(form.role) }}
                </div>
                <div>
                    {{ form_row(form.status) }}
                </div>
            </div>

            <!-- Password Field (only for new users) -->
            {% if form.password is defined %}
            <div>
                {{ form_row(form.password) }}
            </div>
            {% endif %}

            <!-- Notes -->
            <div>
                {{ form_row(form.notes) }}
            </div>

            <!-- Form Actions -->
            <div class="flex items-center justify-end gap-4 pt-6 border-t border-gray-700">
                <a href="{{ path('app_users_index') }}" 
                   class="px-6 py-3 bg-gray-600 hover:bg-gray-700 text-white rounded-lg font-medium transition-colors duration-200">
                    Cancel
                </a>
                <button type="submit" 
                        class="px-6 py-3 bg-[#B32224] hover:bg-red-700 text-white rounded-lg font-medium transition-colors duration-200 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    {% if user.id %}
                        Update User
                    {% else %}
                        Create User
                    {% endif %}
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Form validation
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.querySelector('form');
        if (form) {
            form.addEventListener('submit', function(e) {
                const emailInput = document.querySelector('input[name="user[email]"]');
                const firstNameInput = document.querySelector('input[name="user[firstName]"]');
                const lastNameInput = document.querySelector('input[name="user[lastName]"]');
                const roleSelect = document.querySelector('select[name="user[role]"]');
                
                let isValid = true;
                let errorMessage = '';
                
                if (!emailInput.value) {
                    isValid = false;
                    errorMessage = 'Please enter an email address.';
                } else if (!firstNameInput.value) {
                    isValid = false;
                    errorMessage = 'Please enter a first name.';
                } else if (!lastNameInput.value) {
                    isValid = false;
                    errorMessage = 'Please enter a last name.';
                } else if (!roleSelect.value) {
                    isValid = false;
                    errorMessage = 'Please select a role.';
                }
                
                if (!isValid) {
                    e.preventDefault();
                    showGlobalResultModal('error', 'Validation Error', errorMessage);
                }
            });
        }
    });
</script>
{% endblock %}
