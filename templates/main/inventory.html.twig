{% block javascripts %}
{{ parent() }}
<script>
    window.openAddModal = function() {
        const modal = document.getElementById('addModal');
        const overlay = document.getElementById('modalOverlay');
        const content = document.getElementById('modalContent');
        const formContainer = document.getElementById('addFormContent');

        if (modal && overlay && content && formContainer) {
            // Show loading state
            formContainer.innerHTML = `
                <div class="flex items-center justify-center py-8">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-[#B32224]"></div>
                    <span class="ml-2 text-gray-600">Loading...</span>
                </div>
            `;

            // Prevent background scrolling
            document.body.style.overflow = 'hidden';
            
            // Show modal
            modal.classList.remove('hidden');
            
            // Fade in content with slight delay for smooth animation
            requestAnimationFrame(() => {
                overlay.classList.add('opacity-50');
                content.classList.remove('opacity-0', 'scale-95');
                content.classList.add('opacity-100', 'scale-100');
            });

            // Load form via AJAX (use inventory route)
            fetch('{{ path('app_inventory_new') }}', {
                credentials: 'same-origin',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
                .then(response => response.text())
                .then(html => {
                    formContainer.innerHTML = html;
                    
                    // Re-initialize Stimulus controllers on newly added content
                    if (window.Stimulus) {
                        const application = window.Stimulus.application;
                        if (application && application.router) {
                            // Dispatch a custom event to re-scan for Stimulus controllers
                            formContainer.dispatchEvent(new CustomEvent('stimulus:connect'));
                            // Or manually find and initialize image-preview controller if present
                            const imagePreviewElement = formContainer.querySelector('[data-controller="image-preview"]');
                            if (imagePreviewElement && application) {
                                application.router.discoverElements();
                            }
                        }
                    }
                    
                    // Update form action and add new-specific attributes
                    const form = formContainer.querySelector('#carForm');
                    if (form) {
                        form.action = '{{ path('app_inventory_create') }}';
                        form.setAttribute('data-new-mode', 'true');
                    }
                })
                .catch(error => {
                    console.error('Error loading form:', error);
                    formContainer.innerHTML = `
                        <div class="text-center py-8">
                            <p class="text-red-600">Error loading form. Please try again.</p>
                            <button onclick="closeAddModal()" class="mt-4 px-4 py-2 bg-gray-500 text-white rounded-lg">
                                Close
                            </button>
                        </div>
                    `;
                });
        }
    }

    window.closeAddModal = function() {
        const modal = document.getElementById('addModal');
        const overlay = document.getElementById('modalOverlay');
        const content = document.getElementById('modalContent');

        if (modal && overlay && content) {
            content.classList.remove('opacity-100', 'scale-100');
            content.classList.add('opacity-0', 'scale-95');

            // Add fade-out transition to overlay
            overlay.style.transition = 'opacity 200ms ease-out';
            overlay.style.opacity = '0';

            // Hide modal after animation completes
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
                // Reset overlay styles
                overlay.style.transition = '';
                overlay.style.opacity = '';
                // Clear form content
                document.getElementById('addFormContent').innerHTML = '';
            }, 200);
        }
    }

    // Edit Modal Functions
    window.openEditModal = function(vehicleId) {
        const modal = document.getElementById('editModal');
        const overlay = document.getElementById('editModalOverlay');
        const content = document.getElementById('editModalContent');
        const formContainer = document.getElementById('editFormContent');

        if (modal && overlay && content && formContainer) {
            // Show loading state
            formContainer.innerHTML = `
                <div class="flex items-center justify-center py-8">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-[#B32224]"></div>
                    <span class="ml-2 text-gray-600">Loading...</span>
                </div>
            `;

            // Prevent background scrolling
            document.body.style.overflow = 'hidden';
            
            // Show modal
            modal.classList.remove('hidden');
            
            // Fade in content with slight delay for smooth animation
            requestAnimationFrame(() => {
                overlay.classList.add('opacity-50');
                content.classList.remove('opacity-0', 'scale-95');
                content.classList.add('opacity-100', 'scale-100');
            });

            // Load form via AJAX
            fetch(`/inventory/${vehicleId}/edit`, {
                credentials: 'same-origin',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
                .then(response => response.text())
                .then(html => {
                    formContainer.innerHTML = html;
                    
                    // Update form action and add edit-specific attributes
                    const form = formContainer.querySelector('#carForm');
                    if (form) {
                        form.action = `/inventory/${vehicleId}/edit`;
                        form.setAttribute('data-edit-mode', 'true');
                        form.setAttribute('data-vehicle-id', vehicleId);
                    }
                })
                .catch(error => {
                    console.error('Error loading edit form:', error);
                    formContainer.innerHTML = `
                        <div class="text-center py-8">
                            <p class="text-red-600">Error loading form. Please try again.</p>
                            <button onclick="closeEditModal()" class="mt-4 px-4 py-2 bg-gray-500 text-white rounded-lg">
                                Close
                            </button>
                        </div>
                    `;
                });
        }
    }

    window.closeEditModal = function() {
        const modal = document.getElementById('editModal');
        const overlay = document.getElementById('editModalOverlay');
        const content = document.getElementById('editModalContent');

        if (modal && overlay && content) {
            content.classList.remove('opacity-100', 'scale-100');
            content.classList.add('opacity-0', 'scale-95');

            // Add fade-out transition to overlay
            overlay.style.transition = 'opacity 200ms ease-out';
            overlay.style.opacity = '0';

            // Hide modal after animation completes
            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
                // Reset overlay styles
                overlay.style.transition = '';
                overlay.style.opacity = '';
                // Clear form content
                document.getElementById('editFormContent').innerHTML = '';
            }, 200);
        }
    }

    // Function to show flash messages using global modal
    window.showFlashMessage = function(type, message) {
        showGlobalResultModal(type, type === 'success' ? 'Success!' : 'Error!', message, {
            buttons: [
                {
                    text: 'Add New',
                    class: 'px-4 py-2 bg-[#B32224] border border-transparent rounded-md text-sm font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#B32224]',
                    action: function() {
                        closeGlobalResultModal();
                        setTimeout(() => {
                            document.getElementById('carForm').reset();
                            openAddModal();
                        }, 200);
                    }
                },
                {
                    text: 'OK',
                    class: 'px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#B32224]',
                    action: function() {
                        closeGlobalResultModal();
                        window.location.reload();
                    }
                }
            ]
        });
    }

    window.closeResultModal = function() {
        closeGlobalResultModal();
    }

    window.handleAddNew = function() {
        closeGlobalResultModal();
        setTimeout(() => {
            document.getElementById('carForm').reset();
            openAddModal();
        }, 200);
    }

    // Handle form submission for both add and edit modes
    document.addEventListener('submit', function(e) {
        const form = e.target;
        if (form.id === 'carForm') {
            const submitBtn = form.querySelector('button[type="submit"]');

                // Handle "add new" inside modal via AJAX to avoid navigating away from inventory
            if (form.dataset.newMode === 'true') {
                e.preventDefault();

                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<svg class="animate-spin h-5 w-5 mr-2 inline-block" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Saving...';
                }

                const formData = new FormData(form);
                
                // Get CSRF token from form's hidden input
                const csrfTokenInput = form.querySelector('input[name="_token"]');
                const csrfToken = csrfTokenInput ? csrfTokenInput.value : null;

                fetch(form.action || '{{ path('app_inventory_create') }}', {
                    credentials: 'same-origin',
                    method: 'POST',
                    body: formData,
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                        ...(csrfToken && { 'X-CSRF-TOKEN': csrfToken })
                    }
                })
                    .then(async (response) => {
                        const contentType = response.headers.get('content-type') || '';
                        // Prefer JSON if server sends it, otherwise fall back to HTML form content
                        if (contentType.includes('application/json')) {
                            return response.json();
                        }
                        const text = await response.text();
                        return { success: response.ok, form: text, message: response.ok ? null : 'Form validation failed.' };
                    })
                    .then(data => {
                        if (data.success) {
                            closeAddModal();
                            if (data.redirect) {
                                window.location.href = data.redirect;
                            } else {
                                window.location.reload();
                            }
                        } else {
                            // If server sent back the form HTML, re-render it so the user can fix errors
                            if (data.form) {
                                console.error('Form validation errors:', data.errors);
                                if (data.errors && data.errors.length > 0) {
                                    data.errors.forEach(error => {
                                        console.error(`  - ${error.field}: ${error.message}`);
                                    });
                                }
                                const container = document.getElementById('addFormContent');
                                if (container) {
                                    container.innerHTML = data.form;
                                    const newForm = container.querySelector('#carForm');
                                    if (newForm) {
                                        newForm.action = '{{ path('app_inventory_create') }}';
                                        newForm.setAttribute('data-new-mode', 'true');
                                    }
                                }
                                // Show inline form errors; skip global error modal
                                return;
                            }
                            showFlashMessage('error', data.message || 'Form validation failed.');
                        }
                    })
                    .catch(() => {
                        showFlashMessage('error', 'Unable to add vehicle. Please try again.');
                    })
                    .finally(() => {
                        if (submitBtn) {
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = form.dataset.editMode ? 'Update Vehicle' : 'Save Vehicle';
                        }
                    });

                return;
            }

            // Default non-AJAX behaviour (edit mode)
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<svg class="animate-spin h-5 w-5 mr-2 inline-block" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Saving...';
            }
        }
    });


    // Function to attach overlay click handlers
    function attachOverlayHandlers() {
        const modalOverlay = document.getElementById('modalOverlay');
        const editModalOverlay = document.getElementById('editModalOverlay');
        
        if (modalOverlay) {
            modalOverlay.removeEventListener('click', closeAddModal);
            modalOverlay.addEventListener('click', closeAddModal);
        }
        if (editModalOverlay) {
            editModalOverlay.removeEventListener('click', closeEditModal);
            editModalOverlay.addEventListener('click', closeEditModal);
        }
    }

    // Initialize on both DOMContentLoaded and Turbo events
    function initializeInventoryPage() {
        attachOverlayHandlers();
        initializePriceSlider();
        
        // Check for auto-open modal parameter
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('openModal') === 'add') {
            // Small delay to ensure page is fully loaded
            setTimeout(() => {
                openAddModal();
                // Clean up URL parameter without page reload
                const url = new URL(window.location);
                url.searchParams.delete('openModal');
                window.history.replaceState({}, '', url);
            }, 300);
        }
    }

    // Check if document is already loaded
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeInventoryPage);
    } else {
        initializeInventoryPage();
    }
    
    document.addEventListener('turbo:load', initializeInventoryPage);
    document.addEventListener('turbo:render', initializeInventoryPage);

    // Handle delete vehicle
    window.handleDelete = function(vehicleId, token) {
        if (!confirm('Are you sure you want to delete this vehicle?')) {
            return;
        }
        
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/inventory/${vehicleId}`;
        
        const tokenInput = document.createElement('input');
        tokenInput.type = 'hidden';
        tokenInput.name = '_token';
        tokenInput.value = token;
        
        form.appendChild(tokenInput);
        document.body.appendChild(form);
        form.submit();
    };

    // Image deletion function
    window.removeExistingImage = function(imageName, button) {
        if (confirm('Are you sure you want to remove this image?')) {
            const preview = button.closest('[data-image]');
            if (preview) {
                const hiddenInput = document.createElement('input');
                hiddenInput.type = 'hidden';
                hiddenInput.name = 'images_to_delete[]';
                hiddenInput.value = imageName;
                preview.appendChild(hiddenInput);
                
                preview.style.transition = 'opacity 0.3s ease-out';
                preview.style.opacity = '0';
                setTimeout(() => {
                    preview.style.display = 'none';
                }, 300);
            }
        }
    };

    // Enhanced Image Lightbox with Navigation
    window.openImageLightbox = function(imageSrc, caption) {
        const lightbox = document.getElementById('imageLightbox');
        const lightboxImage = document.getElementById('lightboxImage');
        const lightboxCaption = document.getElementById('lightboxCaption');
        
        lightboxImage.src = imageSrc;
        lightboxImage.alt = caption;
        lightboxCaption.textContent = caption;
        
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        
        // Add fade-in animation
        requestAnimationFrame(() => {
            lightbox.style.opacity = '1';
        });
    };

    window.closeImageLightbox = function() {
        const lightbox = document.getElementById('imageLightbox');
        lightbox.style.opacity = '0';
        setTimeout(() => {
            lightbox.classList.add('hidden');
            document.body.style.overflow = 'auto';
        }, 300);
    };

    // Filter toggle functionality
    function toggleFilters() {
        const filterContent = document.getElementById('filterContent');
        const toggleText = document.getElementById('filterToggleText');
        
        if (filterContent && toggleText) {
            if (filterContent.classList.contains('hidden')) {
                filterContent.classList.remove('hidden');
                toggleText.textContent = 'Hide Filters';
            } else {
                filterContent.classList.add('hidden');
                toggleText.textContent = 'Show Filters';
            }
        }
    }

    // Custom dual thumb price range slider functionality
    function initializePriceSlider() {
        const container = document.getElementById('dual-range-container');
        const minThumb = document.getElementById('min-thumb');
        const maxThumb = document.getElementById('max-thumb');
        const minInput = document.getElementById('price-min-input');
        const maxInput = document.getElementById('price-max-input');
        const minDisplay = document.getElementById('min-price-display');
        const maxDisplay = document.getElementById('max-price-display');
        const activeRange = document.getElementById('price-range-active');
        const minValueInput = document.getElementById('min-value');
        const maxValueInput = document.getElementById('max-value');
        
        if (!container || !minThumb || !maxThumb || !minInput || !maxInput || !minDisplay || !maxDisplay || !activeRange) {
            return;
        }
        
        let minValue = parseInt(minValueInput.value) || 0;
        let maxValue = parseInt(maxValueInput.value) || 2000000;
        let isDragging = false;
        let activeThumb = null;
        
        function updateDisplay() {
            // Update hidden inputs for form submission
            minInput.value = minValue;
            maxInput.value = maxValue;
            minValueInput.value = minValue;
            maxValueInput.value = maxValue;
            
            // Update displays
            minDisplay.textContent = '₱' + minValue.toLocaleString();
            maxDisplay.textContent = '₱' + maxValue.toLocaleString();
            
            // Update thumb positions
            const minPercent = (minValue / 2000000) * 100;
            const maxPercent = (maxValue / 2000000) * 100;
            
            minThumb.style.left = minPercent + '%';
            maxThumb.style.left = maxPercent + '%';
            
            // Update active range visual
            activeRange.style.left = minPercent + '%';
            activeRange.style.width = (maxPercent - minPercent) + '%';
        }
        
        function getValueFromPosition(x) {
            const rect = container.getBoundingClientRect();
            const percent = Math.max(0, Math.min(100, ((x - rect.left) / rect.width) * 100));
            return Math.round((percent / 100) * 2000000 / 50000) * 50000;
        }
        
        function startDrag(e, thumb) {
            isDragging = true;
            activeThumb = thumb;
            e.preventDefault();
            
            if (thumb === minThumb) {
                minThumb.style.zIndex = '40';
                maxThumb.style.zIndex = '30';
            } else {
                maxThumb.style.zIndex = '40';
                minThumb.style.zIndex = '30';
            }
        }
        
        function drag(e) {
            if (!isDragging || !activeThumb) return;
            
            const newValue = getValueFromPosition(e.clientX);
            
            if (activeThumb === minThumb) {
                if (newValue < maxValue - 50000) {
                    minValue = newValue;
                } else {
                    minValue = maxValue - 50000;
                }
            } else {
                if (newValue > minValue + 50000) {
                    maxValue = newValue;
                } else {
                    maxValue = minValue + 50000;
                }
            }
            
            updateDisplay();
        }
        
        function stopDrag() {
            isDragging = false;
            activeThumb = null;
            minThumb.style.zIndex = '30';
            maxThumb.style.zIndex = '30';
        }
        
        // Mouse events
        minThumb.addEventListener('mousedown', (e) => startDrag(e, minThumb));
        maxThumb.addEventListener('mousedown', (e) => startDrag(e, maxThumb));
        
        document.addEventListener('mousemove', drag);
        document.addEventListener('mouseup', stopDrag);
        
        // Touch events for mobile
        minThumb.addEventListener('touchstart', (e) => {
            e.preventDefault();
            startDrag(e.touches[0], minThumb);
        });
        
        maxThumb.addEventListener('touchstart', (e) => {
            e.preventDefault();
            startDrag(e.touches[0], maxThumb);
        });
        
        document.addEventListener('touchmove', (e) => {
            e.preventDefault();
            drag(e.touches[0]);
        });
        
        document.addEventListener('touchend', stopDrag);
        
        // Click on track to move nearest thumb
        container.addEventListener('click', (e) => {
            if (e.target === container || e.target.classList.contains('bg-gray-600')) {
                const clickValue = getValueFromPosition(e.clientX);
                const minDistance = Math.abs(clickValue - minValue);
                const maxDistance = Math.abs(clickValue - maxValue);
                
                if (minDistance < maxDistance) {
                    if (clickValue < maxValue - 50000) {
                        minValue = clickValue;
                    } else {
                        minValue = maxValue - 50000;
                    }
                } else {
                    if (clickValue > minValue + 50000) {
                        maxValue = clickValue;
                    } else {
                        maxValue = minValue + 50000;
                    }
                }
                
                updateDisplay();
            }
        });
        
        // Initialize on page load
        updateDisplay();
    }

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            const addModal = document.getElementById('addModal');
            const editModal = document.getElementById('editModal');
            const imageLightbox = document.getElementById('imageLightbox');
            
            if (!addModal.classList.contains('hidden')) {
                closeAddModal();
            } else if (!editModal.classList.contains('hidden')) {
                closeEditModal();
            } else if (!imageLightbox.classList.contains('hidden')) {
                closeImageLightbox();
            }
        }
    });
</script>
{% endblock %}