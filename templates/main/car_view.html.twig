{% extends 'base.html.twig' %}

{% block title %}{{ car.brand }} Details{% endblock %}

{% block body %}
    
    {{ include('main/car_details.html.twig', {'car': car}) }}

    <!-- Edit Vehicle Modal -->
    <div id="editModal" class="hidden fixed inset-0 z-40">
        <!-- Overlay -->
        <div id="editModalOverlay" class="fixed inset-0 bg-black bg-opacity-50"></div>
        
        <!-- Modal Container -->
        <div class="fixed inset-0 z-40 overflow-y-auto">
            <div class="flex min-h-full items-center justify-center p-4">
                <!-- Modal Content -->
                <div id="editModalContent" class="relative bg-white rounded-lg shadow-xl w-full max-w-2xl transform transition-all opacity-0 scale-95">
                    <!-- Header -->
                    <div class="flex items-center justify-between p-4 border-b border-gray-200">
                        <h3 class="text-lg font-semibold text-gray-900">Edit Vehicle</h3>
                        <button type="button" onclick="closeEditModal()" class="text-gray-400 hover:text-gray-600">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                        </button>
                    </div>

                    <!-- Body -->
                    <div class="p-6">
                        <div id="editFormContent">
                            <!-- Form will be loaded here via AJAX -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Edit Modal Functions
    window.openEditModal = function(vehicleId) {
        const modal = document.getElementById('editModal');
        const overlay = document.getElementById('editModalOverlay');
        const content = document.getElementById('editModalContent');
        const formContainer = document.getElementById('editFormContent');

        if (modal && overlay && content && formContainer) {
            // Show loading state
            formContainer.innerHTML = `
                <div class="flex items-center justify-center py-8">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-500"></div>
                    <span class="ml-2 text-gray-600">Loading...</span>
                </div>
            `;

            // Prevent background scrolling
            document.body.style.overflow = 'hidden';
            
            // Show modal
            modal.classList.remove('hidden');
            
            // Fade in content
            requestAnimationFrame(() => {
                overlay.classList.add('opacity-50');
                content.classList.remove('opacity-0', 'scale-95');
                content.classList.add('opacity-100', 'scale-100');
            });

            // Load form via AJAX
            fetch(`/inventory/${vehicleId}/edit`)
                .then(response => response.text())
                .then(html => {
                    formContainer.innerHTML = html;
                    
                    const form = formContainer.querySelector('#carForm');
                    if (form) {
                        form.action = `/inventory/${vehicleId}/edit`;
                        form.setAttribute('data-edit-mode', 'true');
                        form.setAttribute('data-vehicle-id', vehicleId);
                    }
                })
                .catch(error => {
                    console.error('Error loading edit form:', error);
                    formContainer.innerHTML = `
                        <div class="text-center py-8">
                            <p class="text-red-600">Error loading form. Please try again.</p>
                            <button onclick="closeEditModal()" class="mt-4 px-4 py-2 bg-gray-500 text-white rounded-lg">Close</button>
                        </div>
                    `;
                });
        }
    }

    window.closeEditModal = function() {
        const modal = document.getElementById('editModal');
        const overlay = document.getElementById('editModalOverlay');
        const content = document.getElementById('editModalContent');

        if (modal && overlay && content) {
            content.classList.remove('opacity-100', 'scale-100');
            content.classList.add('opacity-0', 'scale-95');
            overlay.style.transition = 'opacity 200ms ease-out';
            overlay.style.opacity = '0';

            setTimeout(() => {
                modal.classList.add('hidden');
                document.body.style.overflow = 'auto';
                overlay.style.transition = '';
                overlay.style.opacity = '';
                document.getElementById('editFormContent').innerHTML = '';
            }, 200);
        }
    }

    window.handleDelete = function(vehicleId, token) {
        if (!confirm('Are you sure you want to delete this vehicle?')) {
            return;
        }
        
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/inventory/${vehicleId}`;
        
        const tokenInput = document.createElement('input');
        tokenInput.type = 'hidden';
        tokenInput.name = '_token';
        tokenInput.value = token;
        
        form.appendChild(tokenInput);
        document.body.appendChild(form);
        form.submit();
    };

    window.removeExistingImage = function(imageName, button) {
        if (confirm('Are you sure you want to remove this image?')) {
            const preview = button.closest('[data-image]');
            if (preview) {
                const hiddenInput = document.createElement('input');
                hiddenInput.type = 'hidden';
                hiddenInput.name = 'images_to_delete[]';
                hiddenInput.value = imageName;
                preview.appendChild(hiddenInput);
                
                preview.style.transition = 'opacity 0.3s ease-out';
                preview.style.opacity = '0';
                setTimeout(() => {
                    preview.style.display = 'none';
                }, 300);
            }
        }
    };

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            const editModal = document.getElementById('editModal');
            if (editModal && !editModal.classList.contains('hidden')) {
                closeEditModal();
            }
        }
    });

    document.getElementById('editModalOverlay')?.addEventListener('click', closeEditModal);

    document.addEventListener('submit', function(e) {
        const form = e.target;
        if (form.id === 'carForm' && form.hasAttribute('data-edit-mode')) {
            e.preventDefault();
            
            const formData = new FormData(form);
            const vehicleId = form.getAttribute('data-vehicle-id');
            
            fetch(form.action, {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (response.ok) {
                    closeEditModal();
                    // Reload the page to show updated data
                    window.location.reload();
                } else {
                    alert('Error updating vehicle. Please try again.');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error updating vehicle. Please try again.');
            });
        }
    });

</script>
{% endblock %}

