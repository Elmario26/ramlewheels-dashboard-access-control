{% extends 'base.html.twig' %}

{% block title %}{{ customer.id ? 'Edit Customer' : 'Add New Customer' }}{% endblock %}

{% block body %}
    <div class="max-w-4xl mx-auto">
        <!-- Header Section -->
        <div class="mb-8">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-gray-100">
                        {{ customer.id ? 'Edit Customer' : 'Add New Customer' }}
                    </h1>
                    <p class="mt-2 text-gray-400">
                        {{ customer.id ? 'Update customer information' : 'Add a new customer to your database' }}
                    </p>
                </div>
                <a href="{{ path('app_customers_index') }}" 
                   class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition-colors duration-200 shadow-lg hover:shadow-xl">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                    </svg>
                    Back to Customers
                </a>
            </div>
        </div>


        <!-- Form Section -->
        <div class="bg-gray-800 rounded-xl shadow-lg p-8 border border-gray-700">
            {{ form_start(form, {'attr': {'class': 'space-y-6', 'id': 'customerForm', 'data-turbo': 'true'}}) }}
            
            <!-- Personal Information -->
            <div class="border-b border-gray-700 pb-6">
                <h3 class="text-lg font-semibold text-white mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-[#B32224]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    Personal Information
                </h3>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div>
                        {{ form_label(form.firstName, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-2'}}) }}
                        {{ form_widget(form.firstName) }}
                        {{ form_errors(form.firstName) }}
                    </div>
                    <div>
                        {{ form_label(form.lastName, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-2'}}) }}
                        {{ form_widget(form.lastName) }}
                        {{ form_errors(form.lastName) }}
                    </div>
                </div>
            </div>

            <!-- Contact Information -->
            <div class="border-b border-gray-700 pb-6">
                <h3 class="text-lg font-semibold text-white mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-[#B32224]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    Contact Information
                </h3>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div>
                        {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-2'}}) }}
                        {{ form_widget(form.email) }}
                        {{ form_errors(form.email) }}
                    </div>
                    <div>
                        {{ form_label(form.phone, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-2'}}) }}
                        <div class="flex">
                            <!-- Country Code Dropdown -->
                            <button id="dropdown-phone-button" data-dropdown-toggle="dropdown-phone" class="shrink-0 z-10 inline-flex items-center py-3 px-4 text-sm font-medium text-center text-gray-100 bg-gray-700 border border-gray-600 rounded-l-lg hover:bg-gray-600 focus:ring-4 focus:outline-none focus:ring-gray-700" type="button">
                                <svg fill="none" aria-hidden="true" class="h-4 w-4 me-2" viewBox="0 0 20 15">
                                    <rect width="19.6" height="14" y=".5" fill="#fff" rx="2"/>
                                    <mask id="ph-flag-button" style="mask-type:luminance" width="20" height="15" x="0" y="0" maskUnits="userSpaceOnUse">
                                        <rect width="19.6" height="14" y=".5" fill="#fff" rx="2"/>
                                    </mask>
                                    <g mask="url(#ph-flag-button)">
                                        <!-- White triangle -->
                                        <path fill="#fff" d="M0 0h20v14H0z"/>
                                        <path fill="#0038A8" d="M6.67 0H20v7H6.67z"/>   <!-- Blue top -->
                                        <path fill="#CE1126" d="M6.67 7H20v7H6.67z"/>    <!-- Red bottom -->
                                        <path fill="#fff" d="M0 0l6.67 7L0 14V0z"/>       <!-- White triangle -->

                                        <!-- Sun -->
                                        <circle cx="3.2" cy="7" r="1" fill="#FCD116"/>
                                        <g stroke="#FCD116" stroke-width="0.3">
                                            <path d="M3.2 4.5v-1.3M3.2 11.5v-1.3M1.3 7H0M6.4 7H5.1M1.9 5.1l-.9-.9M5.4 10.8l-.9-.9M1 9.9l.9-.9M5.4 3.2l-.9.9"/>
                                        </g>

                                        <!-- Three stars -->
                                        <polygon fill="#FCD116" points="1.2,1.2 1.5,2 0.7,1.6 1.7,1.6 0.9,2"/>
                                        <polygon fill="#FCD116" points="1.2,12.8 1.5,13.6 0.7,13.2 1.7,13.2 0.9,13.6"/>
                                        <polygon fill="#FCD116" points="6,7 6.3,7.8 5.5,7.4 6.5,7.4 5.7,7.8"/>
                                    </g>
                                </svg>
                                +63
                                <svg class="w-2.5 h-2.5 ms-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
                                </svg>
                            </button>
                            
                            <!-- Dropdown Menu -->
                            <div id="dropdown-phone" class="z-10 hidden bg-gray-800 divide-y divide-gray-700 rounded-lg shadow-lg w-52 border border-gray-600">
                                <ul class="py-2 text-sm text-gray-200" aria-labelledby="dropdown-phone-button">
                                    <li>
                                        <button type="button" class="inline-flex w-full px-4 py-2 text-sm text-gray-200 hover:bg-gray-700" role="menuitem" data-country="ph" data-code="+63">
                                            <span class="inline-flex items-center">
                                                <svg fill="none" aria-hidden="true" class="h-4 w-4 me-2" viewBox="0 0 20 15">
                                                    <rect width="19.6" height="14" y=".5" fill="#fff" rx="2"/>
                                                    <mask id="ph-flag-dropdown" style="mask-type:luminance" width="20" height="15" x="0" y="0" maskUnits="userSpaceOnUse">
                                                        <rect width="19.6" height="14" y=".5" fill="#fff" rx="2"/>
                                                    </mask>
                                                    <g mask="url(#ph-flag-dropdown)">
                                                        <!-- White triangle -->
                                                        <path fill="#fff" d="M0 0h20v14H0z"/>
                                                        <path fill="#0038A8" d="M6.67 0H20v7H6.67z"/>   <!-- Blue top -->
                                                        <path fill="#CE1126" d="M6.67 7H20v7H6.67z"/>    <!-- Red bottom -->
                                                        <path fill="#fff" d="M0 0l6.67 7L0 14V0z"/>       <!-- White triangle -->

                                                        <!-- Sun -->
                                                        <circle cx="3.2" cy="7" r="1" fill="#FCD116"/>
                                                        <g stroke="#FCD116" stroke-width="0.3">
                                                            <path d="M3.2 4.5v-1.3M3.2 11.5v-1.3M1.3 7H0M6.4 7H5.1M1.9 5.1l-.9-.9M5.4 10.8l-.9-.9M1 9.9l.9-.9M5.4 3.2l-.9.9"/>
                                                        </g>

                                                        <!-- Three stars -->
                                                        <polygon fill="#FCD116" points="1.2,1.2 1.5,2 0.7,1.6 1.7,1.6 0.9,2"/>
                                                        <polygon fill="#FCD116" points="1.2,12.8 1.5,13.6 0.7,13.2 1.7,13.2 0.9,13.6"/>
                                                        <polygon fill="#FCD116" points="6,7 6.3,7.8 5.5,7.4 6.5,7.4 5.7,7.8"/>

                                                    </g>
                                                </svg>
                                                Philippines (+63)
                                            </span>
                                        </button>
                                    </li>
                                </ul>
                            </div>
                            
                            <!-- Phone Number Input -->
                            <div class="relative w-full">
                                {{ form_widget(form.phone, {'attr': {'class': 'block p-3 w-full z-20 text-sm text-gray-100 bg-gray-700 rounded-r-lg border-l-0 border border-gray-600 focus:ring-2 focus:ring-[#B32224] focus:border-transparent transition-all duration-200', 'placeholder': '9123456789', 'id': 'phone-input'}}) }}
                            </div>
                        </div>
                        <p class="mt-1 text-xs text-gray-400">Enter 10-digit phone number starting with 9 (e.g., 9123456789)</p>
                        {{ form_errors(form.phone) }}
                    </div>
                </div>
            </div>

            <!-- Address Information -->
            <div class="border-b border-gray-700 pb-6">
                <h3 class="text-lg font-semibold text-white mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-[#B32224]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Address Information
                </h3>
                <div class="space-y-6">
                    <div>
                        {{ form_label(form.address, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-2'}}) }}
                        {{ form_widget(form.address) }}
                        {{ form_errors(form.address) }}
                    </div>
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <div>
                            {{ form_label(form.city, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-2'}}) }}
                            {{ form_widget(form.city) }}
                            {{ form_errors(form.city) }}
                        </div>
                        <div>
                            {{ form_label(form.zipCode, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-2'}}) }}
                            {{ form_widget(form.zipCode) }}
                            {{ form_errors(form.zipCode) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Additional Information -->
            <div class="pb-6">
                <h3 class="text-lg font-semibold text-white mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-[#B32224]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Additional Information
                </h3>
                <div>
                    {{ form_label(form.notes, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-300 mb-2'}}) }}
                    {{ form_widget(form.notes) }}
                    {{ form_errors(form.notes) }}
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex items-center justify-end gap-4 pt-6 border-t border-gray-700">
                <a href="{{ path('app_customers_index') }}" 
                   class="px-6 py-3 border border-gray-600 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 transition-all duration-200">
                    Cancel
                </a>
                <button type="submit" 
                        class="bg-gradient-to-r from-[#B32224] to-red-700 hover:from-red-700 hover:to-red-800 text-white px-6 py-3 rounded-lg font-medium transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105">
                    {{ customer.id ? 'Update Customer' : 'Create Customer' }}
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Form validation and submission handling
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('customerForm');
        if (!form) {
            console.warn('Customer form not found');
            return;
        }

        // Phone number validation and dropdown functionality
        const phoneInput = form.querySelector('input[name="customer[phone]"]');
        const dropdownButton = document.getElementById('dropdown-phone-button');
        const dropdownMenu = document.getElementById('dropdown-phone');
        
        if (phoneInput) {
            // Phone input validation
            phoneInput.addEventListener('input', function(e) {
                const value = e.target.value;
                const phonePattern = /^9\d{9}$/;
                
                // Remove any non-numeric characters
                const numericValue = value.replace(/\D/g, '');
                
                // Limit to 10 digits
                if (numericValue.length > 10) {
                    e.target.value = numericValue.substring(0, 10);
                } else {
                    e.target.value = numericValue;
                }
                
                // Visual feedback
                if (numericValue.length > 0) {
                    if (phonePattern.test(numericValue)) {
                        e.target.classList.remove('border-red-500');
                        e.target.classList.add('border-green-500');
                    } else {
                        e.target.classList.remove('border-green-500');
                        e.target.classList.add('border-red-500');
                    }
                } else {
                    e.target.classList.remove('border-red-500', 'border-green-500');
                }
            });

            // Validate on blur
            phoneInput.addEventListener('blur', function(e) {
                const value = e.target.value;
                const phonePattern = /^9\d{9}$/;
                
                if (value.length > 0 && !phonePattern.test(value)) {
                    e.target.classList.add('border-red-500');
                    // Show error message
                    let errorMsg = e.target.parentNode.querySelector('.phone-error');
                    if (!errorMsg) {
                        errorMsg = document.createElement('div');
                        errorMsg.className = 'phone-error text-red-400 text-xs mt-1';
                        e.target.parentNode.appendChild(errorMsg);
                    }
                    errorMsg.textContent = 'Phone number must start with 9 and be exactly 10 digits';
                } else {
                    e.target.classList.remove('border-red-500');
                    const errorMsg = e.target.parentNode.querySelector('.phone-error');
                    if (errorMsg) {
                        errorMsg.remove();
                    }
                }
            });
        }

        // Dropdown functionality
        if (dropdownButton && dropdownMenu) {
            // Toggle dropdown
            dropdownButton.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                dropdownMenu.classList.toggle('hidden');
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (!dropdownButton.contains(e.target) && !dropdownMenu.contains(e.target)) {
                    dropdownMenu.classList.add('hidden');
                }
            });

            // Handle country selection
            const countryButtons = dropdownMenu.querySelectorAll('button[data-country]');
            countryButtons.forEach(button => {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    const country = this.getAttribute('data-country');
                    const code = this.getAttribute('data-code');
                    
                    // Update button text
                    const buttonText = dropdownButton.querySelector('span') || dropdownButton;
                    buttonText.textContent = code;
                    
                    // Close dropdown
                    dropdownMenu.classList.add('hidden');
                });
            });
        }

        // Add form submission handler
        form.addEventListener('submit', function(e) {
            // Validate phone number before submission
            if (phoneInput && phoneInput.value.length > 0) {
                const phonePattern = /^9\d{9}$/;
                if (!phonePattern.test(phoneInput.value)) {
                    e.preventDefault();
                    alert('Please enter a valid phone number starting with 9 and containing exactly 10 digits.');
                    return false;
                }
            }

            // Disable submit button to prevent double submission
            const submitBtn = form.querySelector('button[type="submit"]');
            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<svg class="animate-spin h-5 w-5 mr-2 inline-block" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Saving...';
            }
        });
    });

    // Global error handler to prevent uncaught errors
    window.addEventListener('error', function(e) {
        console.warn('JavaScript error caught:', e.error);
        e.preventDefault();
        return false;
    });

    // Handle unhandled promise rejections
    window.addEventListener('unhandledrejection', function(e) {
        console.warn('Unhandled promise rejection:', e.reason);
        e.preventDefault();
    });
</script>
{% endblock %}
