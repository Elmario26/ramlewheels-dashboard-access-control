{% extends 'base.html.twig' %}

{% block title %}Customer Management{% endblock %}

{% block body %}
    <!-- Header Section -->
    <div class="mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold text-gray-100">Customer Management</h1>
            </div>
            <div class="flex items-center gap-3">
                <!-- Search Form -->
                <form method="GET" action="{{ path('app_customers_search') }}" class="flex items-center gap-2" id="customerSearchForm">
                    <div class="relative">
                        <input type="text" name="q" value="{{ searchQuery ?? '' }}" 
                               placeholder="Search customers by name, email, or phone..." 
                               class="w-64 px-4 py-3 pl-10 bg-gray-700 border border-gray-600 rounded-xl text-gray-100 focus:ring-2 focus:ring-[#B32224] focus:border-transparent hover:border-[#B32224] hover:bg-gray-600 transition-all duration-200 shadow-sm hover:shadow-md"
                               id="searchInput">
                        <svg class="w-5 h-5 absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                        {% if searchQuery is defined and searchQuery %}
                        <button type="button" onclick="clearSearch()" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-gray-200">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                        </button>
                        {% endif %}
                    </div>
                    <button type="submit" class="bg-[#B32224] hover:bg-red-700 text-white px-4 py-2 rounded-lg transition-colors duration-200 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                        Search
                    </button>
                </form>
                <!-- Add Customer Button -->
                <a href="{{ path('app_customers_new') }}" 
                   class="bg-[#B32224] hover:bg-red-700 text-white px-6 py-2.5 rounded-lg flex items-center gap-2 font-medium transition-all duration-200 hover:scale-105 shadow-lg hover:shadow-xl">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                    Add Customer
                </a>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <!-- Total Customers -->
        <div class="bg-gray-800 rounded-lg shadow-lg p-4 border border-gray-700">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-blue-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    <div>
                        <p class="text-gray-400 text-sm font-medium">Total Customers</p>
                        <p class="text-white text-xl font-bold">{{ statistics.total_customers }}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- New This Month -->
        <div class="bg-gray-800 rounded-lg shadow-lg p-4 border border-gray-700">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                    </svg>
                    <div>
                        <p class="text-gray-400 text-sm font-medium">New This Month</p>
                        <p class="text-white text-xl font-bold">{{ statistics.new_this_month }}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Customers with Purchases -->
        <div class="bg-gray-800 rounded-lg shadow-lg p-4 border border-gray-700">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-purple-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <div>
                        <p class="text-gray-400 text-sm font-medium">With Purchases</p>
                        <p class="text-white text-xl font-bold">{{ statistics.customers_with_purchases }}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Conversion Rate -->
        <div class="bg-gray-800 rounded-lg shadow-lg p-4 border border-gray-700">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-amber-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                    </svg>
                    <div>
                        <p class="text-gray-400 text-sm font-medium">Conversion Rate</p>
                        <p class="text-white text-xl font-bold">{{ statistics.conversion_rate }}%</p>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- Error Display -->
    {% if error is defined and error %}
    <div class="mb-6 bg-red-900/20 border border-red-500 rounded-lg p-4">
        <div class="flex items-center">
            <svg class="w-5 h-5 text-red-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-red-300 font-medium">{{ error }}</span>
        </div>
    </div>
    {% endif %}

    <!-- Search Results Indicator -->
    {% if searchQuery is defined and searchQuery %}
    <div class="mb-6 bg-blue-900/20 border border-white rounded-lg p-4">
        <div class="flex items-center justify-between">
            <div class="flex items-center">
                <svg class="w-5 h-5 white mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <span class="text-white font-medium">
                    Search results for "{{ searchQuery }}"
                    {% if customers|length > 0 %}
                        - {{ customers|length }} customer{{ customers|length != 1 ? 's' : '' }} found
                    {% else %}
                        - No customers found
                    {% endif %}
                </span>
            </div>
            <a href="{{ path('app_customers_index') }}" class="text-blue-400 hover:text-blue-300 text-sm font-medium">
                Clear search
            </a>
        </div>
    </div>
    {% endif %}

    <!-- Customers Table -->
    <div class="bg-gray-800 rounded-xl shadow-lg overflow-hidden border border-gray-700">
        <div class="px-6 py-4 border-b border-gray-700">
            <h3 class="text-lg font-semibold text-white">
                {% if searchQuery is defined and searchQuery %}
                    Search Results
                {% else %}
                    Customer Directory
                {% endif %}
            </h3>
        </div>
        
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-700">
                <thead class="bg-gray-900">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Customer</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Contact</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Location</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Purchases</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Total Spent</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-gray-800 divide-y divide-gray-700">
                    {% for customer in customers %}
                    <tr class="hover:bg-gray-700 transition-colors duration-200">
                        <td class="px-6 py-4">
                            <div class="flex items-center">
                                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#B32224] to-red-700 flex items-center justify-center text-white font-semibold text-sm mr-4">
                                    {{ customer.firstName|first|upper }}{{ customer.lastName|first|upper }}
                                </div>
                                <div>
                                    <div class="text-sm font-medium text-gray-100">{{ customer.getFullName() }}</div>
                                    <div class="text-xs text-gray-400">ID: {{ customer.id }}</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-sm text-gray-100">
                                {% if customer.email %}
                                    <div class="flex items-center mb-1">
                                        <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                        </svg>
                                        {{ customer.email }}
                                    </div>
                                {% endif %}
                                {% if customer.phone %}
                                    <div class="flex items-center">
                                        <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                        </svg>
                                        +63 {{ customer.phone }}
                                    </div>
                                {% endif %}
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-400">
                            {% if customer.city %}
                                <div>{{ customer.city }}</div>
                            {% endif %}
                            {% if customer.address %}
                                <div class="text-xs text-gray-500">{{ customer.address }}</div>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-100">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                {{ customer.getPurchaseCount() }} purchases
                            </span>
                        </td>
                        <td class="px-6 py-4 text-sm text-[#B32224] font-semibold">
                            ₱{{ customer.getTotalPurchases()|number_format(2, '.', ',') }}
                        </td>
                        <td class="px-6 py-4 text-sm font-medium space-x-2">
                            <a href="{{ path('app_customers_show', {'id': customer.id}) }}" 
                               class="text-gray-300 hover:text-gray-100 transition-colors duration-200">View</a>
                            <a href="{{ path('app_customers_edit', {'id': customer.id}) }}" 
                               class="text-[#B32224] hover:text-red-600 transition-colors duration-200">Edit</a>
                            <button onclick="handleDelete('{{ customer.id }}', '{{ csrf_token('delete' ~ customer.id) }}')" 
                                    class="text-gray-400 hover:text-gray-200 transition-colors duration-200">Delete</button>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center">
                            <div class="text-gray-400">
                                <svg class="w-12 h-12 mx-auto mb-3 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                                </svg>
                                <p class="text-lg font-medium">No customers found</p>
                                <p class="text-sm">Start by adding your first customer</p>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Handle delete customer with global modal
    window.handleDelete = function(customerId, token) {
        showGlobalResultModal('warning', 'Confirm Delete', 'Are you sure you want to delete this customer? This action cannot be undone.', {
            buttons: [
                {
                    text: 'Cancel',
                    class: 'px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#B32224]',
                    action: function() {
                        closeGlobalResultModal();
                    }
                },
                {
                    text: 'Delete Customer',
                    class: 'px-4 py-2 bg-red-600 text-white rounded-md text-sm font-medium border border-transparent hover:bg-[#B32224] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-700',
                    action: function() {
                        closeGlobalResultModal();
                        
                        // Show loading modal
                        showGlobalResultModal('warning', 'Deleting...', 'Please wait while we delete the customer.');
                        
                        const form = document.createElement('form');
                        form.method = 'POST';
                        form.action = `/customers/${customerId}`;
                        
                        const tokenInput = document.createElement('input');
                        tokenInput.type = 'hidden';
                        tokenInput.name = '_token';
                        tokenInput.value = token;
                        
                        form.appendChild(tokenInput);
                        document.body.appendChild(form);
                        form.submit();
                    }
                }
            ]
        });
    };

    // Search functionality
    function clearSearch() {
        document.getElementById('searchInput').value = '';
        window.location.href = '{{ path('app_customers_index') }}';
    }

    // Auto-submit search on Enter key
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    document.getElementById('customerSearchForm').submit();
                }
            });
        }
    });

    // Focus search input on page load if there's a search query
    {% if searchQuery is defined and searchQuery %}
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.focus();
            searchInput.select(); // Select all text for easy replacement
        }
    });
    {% endif %}
</script>
{% endblock %}
