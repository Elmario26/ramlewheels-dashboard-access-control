{% extends 'base.html.twig' %}

{% block title %}Service Management{% endblock %}

{% block body %}
    <!-- Header Section -->
    <div class="mb-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-3xl font-bold text-gray-100">Service Management</h1>
            </div>
            <div class="flex items-center gap-3">
                <!-- Search Form -->
                <form method="GET" action="{{ path('app_services_search') }}" class="flex items-center gap-2" id="serviceSearchForm">
                    <div class="relative">
                        <input type="text" name="q" value="{{ searchQuery ?? '' }}" 
                               placeholder="Search services by type, customer, or vehicle..." 
                               class="w-64 px-4 py-3 pl-10 bg-gray-700 border border-gray-600 rounded-xl text-gray-100 focus:ring-2 focus:ring-[#B32224] focus:border-transparent hover:border-[#B32224] hover:bg-gray-600 transition-all duration-200 shadow-sm hover:shadow-md"
                               id="searchInput">
                        <svg class="w-5 h-5 absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                        {% if searchQuery is defined and searchQuery %}
                        <button type="button" onclick="clearSearch()" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-gray-200">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                            </svg>
                        </button>
                        {% endif %}
                    </div>
                    <button type="submit" class="bg-[#B32224] hover:bg-red-700 text-white px-4 py-2 rounded-lg transition-colors duration-200 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                        Search
                    </button>
                </form>
                <!-- Add Service Button -->
                <a href="{{ path('app_services_new') }}" 
                   class="bg-[#B32224] hover:bg-red-700 text-white px-6 py-2.5 rounded-lg flex items-center gap-2 font-medium transition-all duration-200 hover:scale-105 shadow-lg hover:shadow-xl">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                    Add Service
                </a>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <!-- Total Services -->
        <div class="bg-gray-800 rounded-lg shadow-lg p-4 border border-gray-700">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-blue-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                    </svg>
                    <div>
                        <p class="text-gray-400 text-sm font-medium">Total Services</p>
                        <p class="text-white text-xl font-bold">{{ statistics.total_services }}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Completed Services -->
        <div class="bg-gray-800 rounded-lg shadow-lg p-4 border border-gray-700">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <div>
                        <p class="text-gray-400 text-sm font-medium">Completed</p>
                        <p class="text-white text-xl font-bold">{{ statistics.completed_services }}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- In Progress Services -->
        <div class="bg-gray-800 rounded-lg shadow-lg p-4 border border-gray-700">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-amber-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <div>
                        <p class="text-gray-400 text-sm font-medium">In Progress</p>
                        <p class="text-white text-xl font-bold">{{ statistics.in_progress_services }}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Revenue -->
        <div class="bg-gray-800 rounded-lg shadow-lg p-4 border border-gray-700">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-purple-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <div>
                        <p class="text-gray-400 text-sm font-medium">Total Revenue</p>
                        <p class="text-white text-xl font-bold">₱{{ statistics.total_revenue|number_format(2, '.', ',') }}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Additional Stats Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        <!-- Pending Services -->
        <div class="bg-gray-800 rounded-lg shadow-lg p-4 border border-gray-700">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-yellow-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                    </svg>
                    <div>
                        <p class="text-gray-400 text-sm font-medium">Pending</p>
                        <p class="text-white text-xl font-bold">{{ statistics.pending_services }}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- This Month Services -->
        <div class="bg-gray-800 rounded-lg shadow-lg p-4 border border-gray-700">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-cyan-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <div>
                        <p class="text-gray-400 text-sm font-medium">This Month</p>
                        <p class="text-white text-xl font-bold">{{ statistics.this_month_services }}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Completion Rate -->
        <div class="bg-gray-800 rounded-lg shadow-lg p-4 border border-gray-700">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-emerald-400 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                    </svg>
                    <div>
                        <p class="text-gray-400 text-sm font-medium">Completion Rate</p>
                        <p class="text-white text-xl font-bold">{{ statistics.completion_rate }}%</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search Results Indicator -->
    {% if searchQuery is defined and searchQuery %}
    <div class="mb-6 bg-blue-900/20 border border-white rounded-lg p-4">
        <div class="flex items-center justify-between">
            <div class="flex items-center">
                <svg class="w-5 h-5 white mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <span class="text-white font-medium">
                    Search results for "{{ searchQuery }}"
                    {% if services|length > 0 %}
                        - {{ services|length }} service{{ services|length != 1 ? 's' : '' }} found
                    {% else %}
                        - No services found
                    {% endif %}
                </span>
            </div>
            <a href="{{ path('app_services_index') }}" class="text-blue-400 hover:text-blue-300 text-sm font-medium">
                Clear search
            </a>
        </div>
    </div>
    {% endif %}

    <!-- Services Table -->
    <div class="bg-gray-800 rounded-xl shadow-lg overflow-hidden border border-gray-700">
        <div class="px-6 py-4 border-b border-gray-700">
            <h3 class="text-lg font-semibold text-white">
                {% if searchQuery is defined and searchQuery %}
                    Search Results
                {% else %}
                    Service Directory
                {% endif %}
            </h3>
        </div>
        
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-700">
                <thead class="bg-gray-900">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Service</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Customer</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Vehicle</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Cost</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Date</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-gray-800 divide-y divide-gray-700">
                    {% for service in services %}
                    <tr class="hover:bg-gray-700 transition-colors duration-200">
                        <td class="px-6 py-4">
                            <div class="flex items-center">
                                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#B32224] to-red-700 flex items-center justify-center text-white font-semibold text-sm mr-4">
                                    {{ service.serviceType|first|upper }}
                                </div>
                                <div>
                                    <div class="text-sm font-medium text-gray-100">{{ service.serviceType|replace({'_': ' '})|title }}</div>
                                    {% if service.description %}
                                        <div class="text-xs text-gray-400 truncate max-w-xs">{{ service.description }}</div>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-sm text-gray-100">
                                <div class="font-medium">{{ service.customer.getFullName() }}</div>
                                {% if service.customer.phone %}
                                    <div class="text-xs text-gray-400">+63 {{ service.customer.phone }}</div>
                                {% endif %}
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-400">
                            {% if service.vehicle %}
                                <div>{{ service.vehicle.brand }} {{ service.vehicle.year }}</div>
                                {% if service.vehicle.plateNumber %}
                                    <div class="text-xs text-gray-500">{{ service.vehicle.plateNumber }}</div>
                                {% endif %}
                            {% else %}
                                <span class="text-gray-500">No vehicle</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 text-sm text-[#B32224] font-semibold">
                            ₱{{ service.cost|number_format(2, '.', ',') }}
                        </td>
                        <td class="px-6 py-4">
                            {% set statusColors = {
                                'pending': 'bg-yellow-100 text-yellow-800',
                                'in_progress': 'bg-blue-100 text-blue-800',
                                'completed': 'bg-green-100 text-green-800',
                                'cancelled': 'bg-red-100 text-red-800'
                            } %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ statusColors[service.status] ?? 'bg-gray-100 text-gray-800' }}">
                                {{ service.status|replace({'_': ' '})|title }}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-400">
                            <div>{{ service.serviceDate|date('M d, Y') }}</div>
                            <div class="text-xs text-gray-500">{{ service.serviceDate|date('h:i A') }}</div>
                        </td>
                        <td class="px-6 py-4 text-sm font-medium">
                            <div class="flex items-center gap-3">
                                <a href="{{ path('app_services_show', {'id': service.id}) }}" 
                                   class="text-gray-300 hover:text-gray-100 transition-colors duration-200"
                                   title="View"
                                   aria-label="View service">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                    </svg>
                                </a>

                                <a href="{{ path('app_services_edit', {'id': service.id}) }}" 
                                   class="text-[#B32224] hover:text-red-600 transition-colors duration-200"
                                   title="Edit"
                                   aria-label="Edit service">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </a>

                                {% if service.status == 'pending' %}
                                    <form method="POST" action="{{ path('app_services_start', {'id': service.id}) }}" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('start' ~ service.id) }}">
                                        <button type="submit" class="text-blue-400 hover:text-blue-300 transition-colors duration-200" title="Start service" aria-label="Start service">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3l14 9-14 9V3z"/>
                                            </svg>
                                        </button>
                                    </form>
                                {% elseif service.status == 'in_progress' %}
                                    <form method="POST" action="{{ path('app_services_complete', {'id': service.id}) }}" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('complete' ~ service.id) }}">
                                        <button type="submit" class="text-green-400 hover:text-green-300 transition-colors duration-200" title="Mark complete" aria-label="Mark complete">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                            </svg>
                                        </button>
                                    </form>
                                {% endif %}

                                {% if is_granted('ROLE_ADMIN') %}
                                <button onclick="handleDelete('{{ service.id }}', '{{ csrf_token('delete' ~ service.id) }}')" 
                                        class="text-gray-400 hover:text-gray-200 transition-colors duration-200"
                                        title="Delete"
                                        aria-label="Delete service">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                </button>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center">
                            <div class="text-gray-400">
                                <svg class="w-12 h-12 mx-auto mb-3 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                                </svg>
                                <p class="text-lg font-medium">No services found</p>
                                <p class="text-sm">Start by adding your first service</p>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Handle delete service with global modal
    window.handleDelete = function(serviceId, token) {
        showGlobalResultModal('warning', 'Confirm Delete', 'Are you sure you want to delete this service? This action cannot be undone.', {
            buttons: [
                {
                    text: 'Cancel',
                    class: 'px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#B32224]',
                    action: function() {
                        closeGlobalResultModal();
                    }
                },
                {
                    text: 'Delete Service',
                    class: 'px-4 py-2 bg-red-600 text-white rounded-md text-sm font-medium border border-transparent hover:bg-[#B32224] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-700',
                    action: function() {
                        closeGlobalResultModal();
                        
                        // Show loading modal
                        showGlobalResultModal('warning', 'Deleting...', 'Please wait while we delete the service.');
                        
                        const form = document.createElement('form');
                        form.method = 'POST';
                        form.action = `/services/${serviceId}`;
                        
                        const tokenInput = document.createElement('input');
                        tokenInput.type = 'hidden';
                        tokenInput.name = '_token';
                        tokenInput.value = token;
                        
                        form.appendChild(tokenInput);
                        document.body.appendChild(form);
                        form.submit();
                    }
                }
            ]
        });
    };

    // Search functionality
    function clearSearch() {
        document.getElementById('searchInput').value = '';
        window.location.href = '{{ path('app_services_index') }}';
    }

    // Auto-submit search on Enter key
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    document.getElementById('serviceSearchForm').submit();
                }
            });
        }
    });

    // Focus search input on page load if there's a search query
    {% if searchQuery is defined and searchQuery %}
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.focus();
            searchInput.select(); // Select all text for easy replacement
        }
    });
    {% endif %}
</script>
{% endblock %}
