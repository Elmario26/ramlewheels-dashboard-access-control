{% extends 'base.html.twig' %}

{% block title %}Settings{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-750 text-gray-100">
    <div class="max-w-6xl mx-auto px-4 py-10 space-y-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-white">Settings</h1>
                <p class="text-sm text-gray-400 mt-2">Manage your account, security, and preferences.</p>
            </div>
            {% if app.user %}
            <div class="flex gap-3">
                <a href="{{ path('app_users_edit', {'id': app.user.id}) }}" class="px-4 py-2 rounded-lg bg-[#b32224] text-white font-semibold hover:bg-red-700 transition">
                    Edit Profile
                </a>
                <a href="{{ path('app_users_change_password', {'id': app.user.id}) }}" class="px-4 py-2 rounded-lg bg-gray-800 text-gray-100 border border-gray-700 hover:border-gray-500 transition">
                    Change Password
                </a>
            </div>
            {% endif %}
        </div>

        {% if app.user %}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Account Info -->
            <div class="bg-gray-800 border border-gray-800 rounded-2xl shadow-2xl overflow-hidden">
                <div class="h-20 bg-secondary relative">
                    <div class="absolute inset-0 opacity-30 bg-[radial-gradient(circle_at_20%_20%,rgba(255,255,255,0.4),transparent_35%),radial-gradient(circle_at_80%_10%,rgba(255,255,255,0.35),transparent_30%),radial-gradient(circle_at_40%_80%,rgba(255,255,255,0.25),transparent_35%)]"></div>
                </div>
                <div class="p-6">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="h-14 w-14 rounded-full bg-gradient-to-br from-[#b32224] to-[#8f1c1e] flex items-center justify-center text-white text-xl font-bold shadow-lg">
                            {{ app.user.firstName|first }}{{ app.user.lastName|first }}
                        </div>
                        <div>
                            <p class="text-lg font-semibold text-white">{{ app.user.firstName }} {{ app.user.lastName }}</p>
                            <p class="text-sm text-gray-400">@{{ app.user.username }}</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                        <div class="bg-gray-850 rounded-xl border border-gray-800 p-3">
                            <p class="text-xs uppercase tracking-wide text-gray-400 mb-1">Email</p>
                            <p class="text-gray-100 font-semibold">{{ app.user.email ?? 'Not set' }}</p>
                        </div>
                        <div class="bg-gray-850 rounded-xl border border-gray-800 p-3">
                            <p class="text-xs uppercase tracking-wide text-gray-400 mb-1">Phone</p>
                            <p class="text-gray-100 font-semibold">{{ app.user.phone ?? 'Not set' }}</p>
                        </div>
                        <div class="bg-gray-850 rounded-xl border border-gray-800 p-3">
                            <p class="text-xs uppercase tracking-wide text-gray-400 mb-1">Role</p>
                            <p class="text-gray-100 font-semibold">{{ app.user.getRoleDisplayName() }}</p>
                        </div>
                        <div class="bg-gray-850 rounded-xl border border-gray-800 p-3">
                            <p class="text-xs uppercase tracking-wide text-gray-400 mb-1">Member since</p>
                            <p class="text-gray-100 font-semibold">{{ app.user.createdAt ? app.user.createdAt|date('M d, Y') : 'N/A' }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Preferences -->
            <div class="bg-gray-800 border border-gray-800 rounded-2xl shadow-2xl p-6 space-y-4">
                <h2 class="text-xl font-semibold text-white">Preferences</h2>
                <div class="space-y-3 text-sm">
                    <div class="flex items-center justify-between bg-gray-850 rounded-xl border border-gray-800 p-3">
                        <div>
                            <p class="text-gray-100 font-semibold">Dark mode</p>
                            <p class="text-xs text-gray-400">Always on (system-wide).</p>
                        </div>
                        <span class="px-3 py-1.5 rounded-lg bg-gray-900 text-gray-300 border border-gray-800">Enabled</span>
                    </div>
                    <div class="flex items-center justify-between bg-gray-850 rounded-xl border border-gray-800 p-3">
                        <div>
                            <p class="text-gray-100 font-semibold">Language</p>
                            <p class="text-xs text-gray-400">Default: English</p>
                        </div>
                        <span class="px-3 py-1.5 rounded-lg bg-gray-900 text-gray-300 border border-gray-800">English</span>
                    </div>
                </div>
            </div>
        </div>
        {% else %}
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 text-center text-gray-100">
                <p class="text-lg font-semibold mb-2">You are not logged in.</p>
                <a href="{{ path('app_login') }}" class="text-[#b32224] font-semibold hover:text-red-300">Go to Login</a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
