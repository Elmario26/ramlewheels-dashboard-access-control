                    </div>
                </div>
            </div>

            {# Bottom Bar #}
            <div class="rw-footer-bottom">
                <div class="rw-footer-bottom-inner">
                    <p class="rw-footer-copyright">&copy; {{ "now"|date("Y") }} Ramle Wheels. All rights reserved.</p>
                    <div class="rw-footer-legal">
                        <a href="#">Privacy</a>
                        <span class="rw-footer-separator">|</span>
                        <a href="#">Terms</a>
                        <span class="rw-footer-separator">|</span>
                        <a href="#">Cookies</a>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script>
        (function () {
            const root = document.querySelector('[data-rw-landing]');
            if (!root) return;

            // Reveal animations
            const revealEls = Array.from(root.querySelectorAll('.rw-reveal'));
            const revealVariants = ['rw-reveal--left', 'rw-reveal--right', 'rw-reveal--zoom', 'rw-reveal--tilt', 'rw-reveal--soft'];

            function pickVariant(index) {
                // Avoid choosing the same animation for consecutive elements
                const base = Math.floor(Math.random() * revealVariants.length);
                const offset = (index % revealVariants.length);
                return revealVariants[(base + offset) % revealVariants.length];
            }

            revealEls.forEach((el, idx) => {
                // Keep explicit "is-visible" elements as-is (hero first paint)
                if (el.classList.contains('is-visible')) return;
                // Allow components to opt-out of random variants
                if (el.hasAttribute('data-rw-reveal-fixed')) return;
                el.classList.add(pickVariant(idx));
            });

            if ('IntersectionObserver' in window) {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('is-visible');
                            observer.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.14, rootMargin: '0px 0px -10% 0px' });

                revealEls.forEach(el => observer.observe(el));
            } else {
                revealEls.forEach(el => el.classList.add('is-visible'));
            }

            // Mobile nav
            const navToggle = root.querySelector('.rw-nav-toggle');
            const mobileNav = root.querySelector('[data-rw-nav-mobile]');

            function setMobileNavOpen(open) {
                if (!navToggle || !mobileNav) return;
                navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
                mobileNav.setAttribute('data-open', open ? 'true' : 'false');
                document.body.style.overflow = open ? 'hidden' : '';
                navToggle.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
            }

            if (navToggle && mobileNav) {
                navToggle.addEventListener('click', () => {
                    const expanded = navToggle.getAttribute('aria-expanded') === 'true';
                    setMobileNavOpen(!expanded);
                });

                // Use event delegation to close nav when clicking any link inside
                mobileNav.addEventListener('click', (e) => {
                    const target = e.target.closest('a, button');
                    if (target && mobileNav.contains(target)) {
                        setMobileNavOpen(false);
                    }
                });
            }

            document.addEventListener('keydown', (e) => {
                if (e.key !== 'Escape' || !mobileNav || mobileNav.getAttribute('data-open') !== 'true') return;
                setMobileNavOpen(false);
                if (navToggle) navToggle.focus();
            });

            // Smooth scroll for in-page CTAs only (anchors)
            const scrollTriggers = root.querySelectorAll('[data-scroll-target]');
            function scrollToTarget(target) {
                const el = document.querySelector(target);
                if (!el) return;
                const headerOffset = 76;
                const rect = el.getBoundingClientRect();
                const y = rect.top + window.scrollY - headerOffset;
                window.scrollTo({ top: y, behavior: 'smooth' });
            }
            scrollTriggers.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const target = btn.getAttribute('data-scroll-target');
                    if (!target || !target.startsWith('#')) return;
                    e.preventDefault();
                    scrollToTarget(target);
                });
            });

            // Explore vehicles dropdown
            const exploreDropdown = root.querySelector('[data-rw-explore-dropdown]');
            const exploreToggles = root.querySelectorAll('[data-rw-explore-toggle]');
            const exploreCloseEls = root.querySelectorAll('[data-rw-explore-close]');
            const headerEl = root.querySelector('.rw-header');

            const exploreGrid = root.querySelector('[data-rw-explore-grid]');
            const exploreBrandList = root.querySelector('[data-rw-brand-list]');
            const mobileTabContainer = document.querySelector('.rw-explore-mobile-tabs');
            let exploreCarsLoaded = false;
            let exploreAllCars = [];
            let exploreSelectedBrand = 'all';
            let currentPage = 1;
            const itemsPerPage = 4;
            let totalPages = 1;
            let paginatedCars = [];

            // Preserve initial server-rendered active state (Home/About/Contact)
            const allNavLinks = Array.from(root.querySelectorAll('.rw-nav-center .rw-nav-link, .rw-nav-mobile-inner .rw-nav-link'));
            const initialActiveNavLinks = allNavLinks.filter((el) => el.classList.contains('is-active'));

            function clearNavActive() {
                allNavLinks.forEach((el) => el.classList.remove('is-active'));
            }

            function restoreInitialNavActive() {
                initialActiveNavLinks.forEach((el) => el.classList.add('is-active'));
            }

            function escapeHtml(input) {
                return String(input ?? '').replace(/[&<>"']/g, (m) => ({
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;',
                }[m]));
            }

            function normalizeCarsPayload(payload) {
                if (!payload) return [];
                if (Array.isArray(payload)) return payload;
                if (payload['hydra:member'] && Array.isArray(payload['hydra:member'])) return payload['hydra:member'];
                if (payload.items && Array.isArray(payload.items)) return payload.items;
                return [];
            }

            function imageSrcFromApi(car) {
                const images = car?.images;
                const first = Array.isArray(images) ? images[0] : null;
                if (!first || typeof first !== 'string') return null;

                if (first.startsWith('http://') || first.startsWith('https://')) return first;
                if (first.startsWith('/')) return first;
                return `/uploads/cars/${first}`;
            }

            function renderExploreCars(cars) {
                if (!exploreGrid) return;
                exploreGrid.innerHTML = '';
                console.log(`renderExploreCars called with ${cars.length} cars`);

                if (!cars || cars.length === 0) {
                    exploreGrid.innerHTML = `<div class="rw-explore-loading" role="status" aria-live="polite">No vehicles found.</div>`;
                    return;
                }

                // Check if mobile (same breakpoint as CSS)
                const isMobile = window.innerWidth <= 640;
                console.log(`isMobile: ${isMobile}`);

                if (isMobile) {
                    // Mobile: Group cars into pages of 4 (2x2 grid per page)
                    const carsPerPage = 4;
                    const pages = [];
                    for (let i = 0; i < cars.length; i += carsPerPage) {
                        pages.push(cars.slice(i, i + carsPerPage));
                    }
                    console.log(`Created ${pages.length} pages with ${carsPerPage} cars per page`);

                    pages.forEach((pageCars, pageIdx) => {
                        console.log(`Rendering page ${pageIdx + 1} with ${pageCars.length} cars`);
                        const pageDiv = document.createElement('div');
                        pageDiv.className = 'rw-explore-page';

                        pageCars.forEach((car, idx) => {
                            const title = [car?.brand, car?.Year, car?.make].filter(Boolean).join(' ');
                            const imgSrc = imageSrcFromApi(car);

                            const card = document.createElement('article');
                            card.className = 'rw-explore-card';

                            card.style.opacity = '0';
                            card.style.transform = 'translateY(10px)';
                            card.style.transition = 'opacity 350ms ease, transform 350ms ease';
                            card.style.transitionDelay = `${idx * 60}ms`;

                            card.innerHTML = `
                                <div class="rw-explore-card-media" aria-hidden="true">
                                    <img ${imgSrc ? `src="${escapeHtml(imgSrc)}"` : 'style="display:none"'} alt="" loading="lazy">
                                </div>
                                <div class="rw-explore-card-body">
                                    <div class="rw-explore-card-title">${escapeHtml(title || 'Vehicle')}</div>
                                    <div class="rw-explore-card-cta">Explore</div>
                                </div>
                            `;

                            pageDiv.appendChild(card);

                            requestAnimationFrame(() => {
                                card.style.opacity = '1';
                                card.style.transform = 'translateY(0)';
                            });
                        });

                        exploreGrid.appendChild(pageDiv);
                        console.log(`Page ${pageIdx + 1} has ${pageDiv.children.length} cards in DOM`);
                    });
                } else {
                    // Desktop: Render cars directly in grid (original layout)
                    console.log(`Rendering ${cars.length} cars in desktop layout`);
                    cars.forEach((car, idx) => {
                        const title = [car?.brand, car?.Year, car?.make].filter(Boolean).join(' ');
                        const imgSrc = imageSrcFromApi(car);

                        const card = document.createElement('article');
                        card.className = 'rw-explore-card';

                        card.style.opacity = '0';
                        card.style.transform = 'translateY(10px)';
                        card.style.transition = 'opacity 350ms ease, transform 350ms ease';
                        card.style.transitionDelay = `${idx * 60}ms`;

                        card.innerHTML = `
                            <div class="rw-explore-card-media" aria-hidden="true">
                                <img ${imgSrc ? `src="${escapeHtml(imgSrc)}"` : 'style="display:none"'} alt="" loading="lazy">
                            </div>
                            <div class="rw-explore-card-body">
                                <div class="rw-explore-card-title">${escapeHtml(title || 'Vehicle')}</div>
                                <div class="rw-explore-card-cta">Explore</div>
                            </div>
                        `;

                        exploreGrid.appendChild(card);

                        requestAnimationFrame(() => {
                            card.style.opacity = '1';
                            card.style.transform = 'translateY(0)';
                        });
                    });
                }
                console.log(`Finished rendering. Total children in exploreGrid: ${exploreGrid.children.length}`);
            }

            function populateBrandList(cars) {
                if (!exploreBrandList) return;

                const brandsSet = new Set();
                cars.forEach(car => {
                    if (car?.brand) {
                        brandsSet.add(car.brand);
                    }
                });

                const brands = Array.from(brandsSet).sort();

                // Keep the "All Brands" button, add the rest
                const allBrandsBtn = exploreBrandList.querySelector('[data-brand-filter="all"]');
                const brandItems = exploreBrandList.querySelectorAll('li:not(:first-child)');
                brandItems.forEach(li => li.remove());

                brands.forEach(brand => {
                    const li = document.createElement('li');
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'rw-explore-brand-btn';
                    btn.textContent = brand;
                    btn.setAttribute('data-brand-filter', brand);
                    btn.addEventListener('click', () => filterByBrand(brand));
                    
                    li.appendChild(btn);
                    exploreBrandList.appendChild(li);
                });

                // Set up "All Brands" click handler
                if (allBrandsBtn) {
                    allBrandsBtn.addEventListener('click', () => filterByBrand('all'));
                }
            }

            function updatePagination(cars) {
                const carsPerPage = 4;
                totalPages = Math.ceil(cars.length / carsPerPage) || 1;
                const textEl = document.querySelector('[data-rw-pagination-text]');
                const paginationContainer = document.querySelector('[data-rw-swiper-pagination]');
                
                // Update page text
                if (textEl) {
                    textEl.textContent = `1 / ${totalPages}`;
                }
                
                // Create/update bullet pagination
                if (paginationContainer) {
                    paginationContainer.innerHTML = '';
                    if (totalPages > 1) {
                        for (let i = 1; i <= totalPages; i++) {
                            const bullet = document.createElement('button');
                            bullet.type = 'button';
                            bullet.className = 'rw-explore-swiper-bullet' + (i === 1 ? ' rw-explore-swiper-bullet--active' : '');
                            bullet.setAttribute('aria-label', `Page ${i}`);
                            bullet.addEventListener('click', (e) => {
                                e.stopPropagation();
                                // Scroll to page
                                const pageWidth = exploreGrid.offsetWidth;
                                exploreGrid.scrollTo({ left: (i - 1) * pageWidth, behavior: 'smooth' });
                            });
                            paginationContainer.appendChild(bullet);
                        }
                    }
                }

                // Update current page on scroll
                if (exploreGrid && totalPages > 1) {
                    exploreGrid.addEventListener('scroll', () => {
                        const pageWidth = exploreGrid.offsetWidth;
                        const newPage = Math.round(exploreGrid.scrollLeft / pageWidth) + 1;
                        if (newPage !== currentPage && newPage >= 1 && newPage <= totalPages) {
                            currentPage = newPage;
                            if (textEl) {
                                textEl.textContent = `${currentPage} / ${totalPages}`;
                            }
                            // Update active bullet
                            const bullets = paginationContainer.querySelectorAll('.rw-explore-swiper-bullet');
                            bullets.forEach((b, idx) => {
                                if (idx + 1 === currentPage) {
                                    b.classList.add('rw-explore-swiper-bullet--active');
                                } else {
                                    b.classList.remove('rw-explore-swiper-bullet--active');
                                }
                            });
                        }
                    }, { passive: true });
                }
            }

            function populateMobileTabs(cars) {
                if (!mobileTabContainer) return;
                
                const brandsSet = new Set();
                cars.forEach(car => {
                    if (car?.brand) brandsSet.add(car.brand);
                });
                
                const brands = Array.from(brandsSet).sort();
                
                // Keep All Brands tab
                const allTab = mobileTabContainer.querySelector('[data-brand-filter="all"]');
                mobileTabContainer.innerHTML = '';
                if (allTab) mobileTabContainer.appendChild(allTab);
                
                brands.forEach(brand => {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'rw-explore-tab-btn';
                    btn.textContent = brand;
                    btn.setAttribute('data-brand-filter', brand);
                    btn.addEventListener('click', () => {
                        currentPage = 1;
                        filterByBrand(brand);
                        updateActiveTab(brand);
                    });
                    mobileTabContainer.appendChild(btn);
                });
                
                // All Brands click handler
                if (allTab) {
                    allTab.addEventListener('click', () => {
                        currentPage = 1;
                        filterByBrand('all');
                        updateActiveTab('all');
                    });
                }
            }

            function updateActiveTab(brand) {
                const tabs = document.querySelectorAll('.rw-explore-tab-btn');
                tabs.forEach(tab => {
                    if (tab.getAttribute('data-brand-filter') === brand) {
                        tab.classList.add('rw-explore-tab-btn--active');
                    } else {
                        tab.classList.remove('rw-explore-tab-btn--active');
                    }
                });
            }

            function filterByBrand(brand) {
                exploreSelectedBrand = brand;
                currentPage = 1;

                // Update active button styling
                const allBrandBtns = exploreBrandList.querySelectorAll('.rw-explore-brand-btn');
                allBrandBtns.forEach(btn => {
                    if (btn.getAttribute('data-brand-filter') === brand) {
                        btn.classList.add('rw-explore-brand-btn--active');
                    } else {
                        btn.classList.remove('rw-explore-brand-btn--active');
                    }
                });

                // Filter and render cars
                let filteredCars = exploreAllCars;
                console.log(`Total cars in exploreAllCars: ${exploreAllCars.length}`);
                if (brand !== 'all') {
                    filteredCars = exploreAllCars.filter(car => car?.brand === brand);
                    console.log(`Filtered to brand "${brand}": ${filteredCars.length} cars`);
                } else {
                    console.log(`Showing all brands: ${filteredCars.length} cars`);
                    console.log('Car brands:', filteredCars.map(c => c.brand).join(', '));
                }

                renderExploreCars(filteredCars);
                updatePagination(filteredCars);
            }

            async function loadExploreCars() {
                if (!exploreGrid || exploreCarsLoaded) return;
                exploreCarsLoaded = true;

                exploreGrid.innerHTML = `<div class="rw-explore-loading" role="status" aria-live="polite">Loading vehicles...</div>`;

                try {
                    const res = await fetch('/api/cars', { headers: { 'Accept': 'application/json' } });
                    if (!res.ok) throw new Error(`HTTP ${res.status}`);
                    const data = await res.json();
                    exploreAllCars = normalizeCarsPayload(data);
                    populateBrandList(exploreAllCars);
                    populateMobileTabs(exploreAllCars);
                    updatePagination(exploreAllCars);
                    renderExploreCars(exploreAllCars);
                } catch (e) {
                    console.error('Failed to load /api/cars', e);
                    exploreGrid.innerHTML = `<div class="rw-explore-loading" role="status" aria-live="polite">Failed to load vehicles.</div>`;
                }
            }

            // Track last known mobile state for resize handling
            let lastIsMobile = window.innerWidth <= 640;

            // Re-render cars when resizing between mobile and desktop
            window.addEventListener('resize', () => {
                const currentIsMobile = window.innerWidth <= 640;
                // Only re-render if we crossed the breakpoint and have cars loaded
                if (currentIsMobile !== lastIsMobile && exploreAllCars.length > 0) {
                    lastIsMobile = currentIsMobile;
                    // Re-render with current filtered cars
                    let filteredCars = exploreAllCars;
                    if (exploreSelectedBrand !== 'all') {
                        filteredCars = exploreAllCars.filter(car => car?.brand === exploreSelectedBrand);
                    }
                    renderExploreCars(filteredCars);
                    updatePagination(filteredCars);
                }
            });

            function setExploreOpen(open) {
                if (!exploreDropdown) return;

                if (headerEl) {
                    const headerH = headerEl.getBoundingClientRect().height || 76;
                    exploreDropdown.style.setProperty('--rw-header-h', `${headerH}px`);
                }

                clearNavActive();

                exploreDropdown.setAttribute('data-open', open ? 'true' : 'false');
                exploreDropdown.setAttribute('aria-hidden', open ? 'false' : 'true');

                exploreToggles.forEach(btn => {
                    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
                    if (open) btn.classList.add('is-active');
                });

                if (!open) {
                    restoreInitialNavActive();
                    // Remove focus from any element inside the dropdown to fix aria-hidden warning
                    const focusedEl = exploreDropdown.querySelector(':focus');
                    if (focusedEl) focusedEl.blur();
                }

                if (open) loadExploreCars();
            }

            exploreToggles.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    const isOpen = exploreDropdown && exploreDropdown.getAttribute('data-open') === 'true';
                    setExploreOpen(!isOpen);
                    // Close mobile nav if open
                    if (mobileNav && mobileNav.getAttribute('data-open') === 'true') {
                        setMobileNavOpen(false);
                    }
                });
            });

            exploreCloseEls.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                    setExploreOpen(false);
                });
            });

            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && exploreDropdown && exploreDropdown.getAttribute('data-open') === 'true') {
                    setExploreOpen(false);
                }
            });

            document.addEventListener('click', (e) => {
                if (!exploreDropdown) return;
                const isOpen = exploreDropdown.getAttribute('data-open') === 'true';
                if (!isOpen) return;

                const target = e.target;
                if (!target) return;

                const clickedInside = exploreDropdown.contains(target) || Array.from(exploreToggles).some((t) => t.contains(target));
                if (!clickedInside) setExploreOpen(false);
            });
        })();
    </script>
</body>
</html>

