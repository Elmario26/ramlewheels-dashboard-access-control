{# ========================================
   USAGE EXAMPLES IN TEMPLATES
   ======================================== #}

{#
    EXAMPLE 1: User Management List Template
    =========================================
    
    {% import 'partials/_permission_snippets.html.twig' as perms %}
    
    <h1>User Directory</h1>
    
    {{ perms.user_create_button() }}
    
    <table>
        {% for user in users %}
            <tr>
                <td>{{ user.fullName }}</td>
                <td>
                    {{ perms.user_edit_button(user) }}
                    {{ perms.user_delete_button(user) }}
                </td>
            </tr>
        {% endfor %}
    </table>

    
    EXAMPLE 2: Vehicle Details Page
    ================================
    
    {% import 'partials/_permission_snippets.html.twig' as perms %}
    
    <div class="vehicle-details">
        <h1>{{ vehicle.brand }} {{ vehicle.model }}</h1>
        
        <div class="actions mt-4">
            <a href="{{ path('app_cars_edit', {id: vehicle.id}) }}">✏️ Edit</a>
            {{ perms.vehicle_delete_button(vehicle) }}
        </div>
    </div>

    
    EXAMPLE 3: Sales Form Page
    ===========================
    
    {% import 'partials/_permission_snippets.html.twig' as perms %}
    
    <form method="POST">
        <!-- form fields -->
        <button type="submit">Submit Sale</button>
    </form>
    
    {{ perms.sales_submit_warning() }}

    
    EXAMPLE 4: Dashboard with Financial Data
    =========================================
    
    {% import 'partials/_permission_snippets.html.twig' as perms %}
    
    <div class="dashboard">
        {{ perms.financial_summary(metrics) }}
        
        {% if is_granted('ROLE_ADMIN') %}
            {{ perms.admin_reports_section() }}
        {% else %}
            {{ perms.staff_basic_reports() }}
        {% endif %}
    </div>
#}
