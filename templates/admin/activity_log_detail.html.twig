{% extends "base.html.twig" %}

{% block title %}Activity Log Details - Admin{% endblock %}

{% block body %}
<div class="fixed inset-0 z-40 flex items-center justify-center px-4 py-6 overflow-hidden">
    <!-- Overlay to mirror vehicle modal style -->
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-3xl bg-gray-900 border border-gray-800 rounded-2xl shadow-2xl overflow-hidden z-10">
        <!-- Header -->
        <div class="flex items-center justify-between px-5 py-3 bg-gray-950 border-b border-gray-800">
            <div>
                <h1 class="text-2xl font-bold text-white">Activity Log Details</h1>
                <p class="text-xs text-gray-400 mt-1">Full context for audit and troubleshooting</p>
            </div>
            <a href="{{ path('app_activity_logs') }}" class="text-gray-400 hover:text-white text-lg font-semibold">&times;</a>
        </div>

        <div class="p-6 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Left Column: User & Action -->
                <div class="space-y-6">
                    <!-- User -->
                    <div>
                        <label class="block text-xs font-semibold text-gray-400 mb-2 uppercase tracking-wide">User</label>
                        {% if log.user %}
                            <div class="flex items-center p-3 bg-gray-850 rounded-xl border border-gray-800">
                                <div class="flex-shrink-0 h-11 w-11 bg-gradient-to-br from-[#b32224] to-[#8f1c1e] rounded-full flex items-center justify-center text-white font-bold text-sm shadow-lg">
                                    {{ log.user.firstName|first }}{{ log.user.lastName|first }}
                                </div>
                                <div class="ml-3">
                                    <p class="text-white font-semibold">{{ log.user.firstName }} {{ log.user.lastName }}</p>
                                    <p class="text-gray-400 text-sm">@{{ log.user.username }}</p>
                                </div>
                            </div>
                            <div class="mt-3 text-sm text-gray-300 space-y-1">
                                <p><span class="font-semibold text-gray-200">Email:</span> {{ log.user.email }}</p>
                                <p><span class="font-semibold text-gray-200">Role:</span>
                                    {% for role in log.user.roles %}
                                        <span class="inline-block bg-[#b32224]/20 text-red-100 px-2 py-1 rounded text-xs font-medium mr-1 border border-[#b32224]/40">
                                            {{ role }}
                                        </span>
                                    {% endfor %}
                                </p>
                            </div>
                        {% else %}
                            <p class="text-gray-500 italic">System Activity (No User)</p>
                        {% endif %}
                    </div>

                    <!-- Action -->
                    <div>
                        <label class="block text-xs font-semibold text-gray-400 mb-2 uppercase tracking-wide">Action</label>
                        <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-semibold border border-gray-800
                            {% if log.action == 'login' %}
                                bg-green-900/40 text-green-100 border-green-700/60
                            {% elseif log.action == 'logout' %}
                                bg-gray-850 text-gray-100 border-gray-750
                            {% elseif log.action == 'create' %}
                                bg-blue-900/40 text-blue-100 border-blue-700/60
                            {% elseif log.action == 'update' %}
                                bg-yellow-900/40 text-yellow-100 border-yellow-700/60
                            {% elseif log.action == 'delete' %}
                                bg-red-900/40 text-red-100 border-red-700/60
                            {% elseif log.action == 'view' %}
                                bg-purple-900/40 text-purple-100 border-purple-700/60
                            {% else %}
                                bg-gray-850 text-gray-100 border-gray-750
                            {% endif %}
                        ">
                            {% set action_label = {
                                'login': 'Login',
                                'logout': 'Logout',
                                'create': 'Create',
                                'update': 'Update',
                                'delete': 'Delete',
                                'view': 'View'
                            } %}
                            {{ action_label[log.action] ?? log.action|upper }}
                        </span>
                    </div>
                </div>

                <!-- Right Column: Description & Timestamp -->
                <div class="space-y-6">
                    {% if log.description %}
                        <div>
                            <label class="block text-xs font-semibold text-gray-400 mb-2 uppercase tracking-wide">Description</label>
                            <p class="text-gray-100 p-4 bg-gray-850 rounded-xl border border-gray-800">{{ log.description }}</p>
                        </div>
                    {% endif %}

                    <div>
                        <label class="block text-xs font-semibold text-gray-400 mb-2 uppercase tracking-wide">Timestamp</label>
                        <p class="text-lg text-white font-semibold">{{ log.createdAt|date('Y-m-d H:i:s') }}</p>
                        <p class="text-sm text-gray-400 mt-1">{{ log.createdAt|date('l, F j, Y') }}</p>
                    </div>

                    {% if log.entityType or log.entityId %}
                        <div>
                            <label class="block text-xs font-semibold text-gray-400 mb-2 uppercase tracking-wide">Affected Entity</label>
                            <div class="p-4 bg-gray-850 rounded-xl border border-gray-800">
                                <p class="text-white font-semibold">{{ log.entityType }}</p>
                                {% if log.entityId %}
                                    <p class="text-sm text-gray-300">ID: <span class="font-mono">{{ log.entityId }}</span></p>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Affected Data Section -->
            {% if log.affectedData %}
                <div class="mt-8 pt-6 border-t border-gray-800">
                    <h3 class="text-lg font-semibold text-white mb-3">Affected Data</h3>
                    
                    {% set data = log.affectedData %}
                    {% if data is not empty %}
                        <div class="bg-gray-850 p-3 rounded-xl border border-gray-800 overflow-x-auto">
                            <table class="min-w-full divide-y divide-gray-800 text-sm">
                                <thead>
                                    <tr class="bg-gray-900/70">
                                        <th class="px-4 py-2 text-left text-sm font-semibold text-gray-200">Field</th>
                                        <th class="px-4 py-2 text-left text-sm font-semibold text-gray-200">Before</th>
                                        <th class="px-4 py-2 text-left text-sm font-semibold text-gray-200">After</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-800">
                                    {% for field, changes in data %}
                                        <tr class="hover:bg-gray-900/60">
                                            <td class="px-4 py-2 text-sm font-medium text-white">{{ field }}</td>
                                            <td class="px-4 py-2 text-sm text-gray-200 font-mono">
                                                {% if changes.before is defined %}
                                                    <span class="bg-red-900/40 text-red-100 px-2 py-1 rounded border border-red-700/60">{{ changes.before|default('-') }}</span>
                                                {% else %}
                                                    <span class="text-gray-500">-</span>
                                                {% endif %}
                                            </td>
                                            <td class="px-4 py-2 text-sm text-gray-200 font-mono">
                                                {% if changes.after is defined %}
                                                    <span class="bg-green-900/40 text-green-100 px-2 py-1 rounded border border-green-700/60">{{ changes.after|default('-') }}</span>
                                                {% else %}
                                                    <span class="text-gray-500">-</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <p class="text-gray-400 italic">No data changes recorded</p>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
